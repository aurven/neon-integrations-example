{
  "name": "neon-integrations-example",
  "version": "1.4.2",
  "description": "A bunch of Neon integrations on a simple Node app built on fastify, instantly up and running.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "npx tailwindcss -i ./src/styles/tailwind-source.css -o ./public/css/tailwind-panels.css --minify",
    "watch:css": "npx tailwindcss -i ./src/styles/tailwind-source.css -o ./public/css/tailwind-panels.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"nodemon --env-file=.env server.js\"",
    "dev:legacy": "node --env-file=.env server.js",
    "test": "node --test test/connectors/twitter-connector.test.js test/connectors/facebook-connector.test.js test/connectors/instagram-connector.test.js test/connectors/threads-connector.test.js test/connectors/connector-registry.test.js test/delayed-importer.test.js test/images-importer-metadata.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "@fastify/cookie": "^9.4.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^6.10.2",
    "@fastify/view": "^8.0.0",
    "@sendgrid/mail": "^8.1.4",
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^5.0.5",
    "chart.js": "^4.4.1",
    "cheerio": "1.0.0-rc.12",
    "dayjs": "^1.11.13",
    "deepl-node": "^1.15.0",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.2.2",
    "fastify": "^4.21.0",
    "form-data": "^4.0.2",
    "handlebars": "^4.7.8",
    "http-cookie-agent": "^7.0.2",
    "mammoth": "^1.9.0",
    "node-html-parser": "^6.1.13",
    "openai": "^5.8.2",
    "pdfkit": "^0.17.2",
    "querystring": "^0.2.1",
    "remove-accents": "^0.5.0",
    "rss-parser": "^3.13.0",
    "tough-cookie": "^4.0.0",
    "unorm": "^1.6.0",
    "xpath": "^0.0.34"
  },
  "engines": {
    "node": "20.x"
  },
  "license": "MIT",
  "keywords": [
    "node"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "tailwindcss": "^3.4.18"
  }
}
