{
  "title": "Articles Grid",
  "demoData": "adn-search-results.json",
  "pollIntervalMs": 20000,
  "workfolderTypes": ["article","wirestory","wirestory/extcontributions","wirestory/afpwirestory","article/take","article/longform","article/poll","hero"],
  "fields": [
    { "key": "headline", "source": "title" },
    { "key": "summary", "source": "summary" },
    { "key": "type", "derived": "typeLabel" },
    { "key": "date", "source": "updateTs" },
    { "key": "status", "derived": "status" },
    { "key": "statusColor", "derived": "statusColor" },
    { "key": "versionInfo", "source": "versionInfo" },
    { "key": "lockInfos", "source": "lockInfos" },
    { "key": "publishInfos", "source": "publishInfos" },
    { "key": "workFolder", "source": "metadataGroups.eom.sys_attributes_json.workFolder" }
  ],
  "icons": {
    "file": "FileText",
    "image": "Image",
    "video": "Video",
    "mic": "Mic",
    "zap": "Zap",
    "rss": "Rss",
    "monitor": "Monitor",
    "copy": "Copy",
    "move": "ArrowRight",
    "send": "Send"
  },
  "typeIcons": {
    "article": "file",
    "article/flash": "zap",
    "gallery": "image",
    "photo": "image",
    "video": "video",
    "audio": "mic"
  },
  "actions": [
    { "id": "copy-wire", "label": "Copia in Wire", "icon": "rss",     "actionType": "moveToWorkspace", "workspaceFilter": "Wire", "showWhen": { "field": "workFolder", "op": "contains", "value": "/Web" } },
    { "id": "copy-web",  "label": "Copia in Web",  "icon": "monitor", "actionType": "moveToWorkspace", "workspaceFilter": "Web",  "showWhen": { "field": "workFolder", "op": "contains", "value": "/Wire" } }
  ],
  "rowColorRules": [
    {
      "when": { "field": "type", "op": "eq", "value": "article/flash" },
      "background": "#fef9c3",
      "label": "flash"
    }
  ],
  "columns": [
    { "field": "status", "headerName": "Stato", "type": "status", "width": 20, "sortable": true, "filter": true, "display": "dot" },
    { "field": "headline", "headerName": "Titolo e Sommario", "type": "headline", "flex": 5, "minWidth": 260, "sortable": true, "filter": true },
    { "field": "type", "headerName": "Tipo", "type": "typeIcon", "width": 100, "sortable": true, "filter": true, "iconOnly": false },
    { "field": "versionInfo.createFamilyTime", "headerName": "Creato", "type": "dateUser", "width": 160, "sortable": true,
      "userField": "versionInfo.createFamilyUserRef.userId", "userAliasField": "versionInfo.createFamilyUserRef.alias" },
    { "field": "lockInfos.USER.locked", "headerName": "Bloccato", "type": "dateUser", "width": 160, "sortable": false,
      "userField": "lockInfos.USER.userUpdateRef.userId", "userAliasField": "lockInfos.USER.userUpdateRef.userName" },
    { "field": "versionInfo.updateVersionTime", "headerName": "Ultima Modifica", "type": "dateUser", "width": 160, "sortable": true,
      "userField": "versionInfo.updateVersionUserRef.userId", "userAliasField": "versionInfo.updateVersionUserRef.alias" },
    { "field": "publishInfos", "headerName": "Pubblicato", "type": "publication", "width": 80,
      "publications": [
        { "id": "Wire", "icon": "rss", "label": "Wire" },
        { "id": "Web", "icon": "monitor", "label": "Web" }
      ]
    },
    { "field": "actions", "headerName": "", "type": "actions", "width": 90 }
  ]
}
