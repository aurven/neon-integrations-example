{
  "title": "Articles Grid",
  "demoData": "search-results.json",
  "pollIntervalMs": 20000,
  "workfolderTypes": ["article","wirestory","wirestory/extcontributions","wirestory/afpwirestory","article/take","article/longform","article/poll","hero"],
  "fields": [
    { "key": "headline", "source": "title" },
    { "key": "summary", "source": "summary" },
    { "key": "type", "derived": "typeLabel" },
    { "key": "date", "source": "updateTs" },
    { "key": "status", "derived": "status" },
    { "key": "statusColor", "derived": "statusColor" },
    { "key": "versionInfo", "source": "versionInfo" },
    { "key": "lockInfos", "source": "lockInfos" },
    { "key": "publishInfos", "source": "publishInfos" },
    { "key": "nodeMeta", "source": "nodeMeta" }
  ],
  "icons": {
    "file": "FileText",
    "image": "Image",
    "video": "Video",
    "mic": "Mic",
    "globe": "Globe",
    "trophy": "Trophy",
    "rocket": "Rocket",
    "copy": "Copy",
    "move": "ArrowRight",
    "send": "Send",
    "zap": "Zap"
  },
  "typeIcons": {
    "article": "file",
    "article/flash": "zap",
    "gallery": "image",
    "photo": "image",
    "video": "video",
    "audio": "mic"
  },
  "actions": [
    { "id": "copy", "label": "Copy", "icon": "copy" },
    { "id": "move", "label": "Move to...", "icon": "move", "actionType": "moveToWorkspace" },
    { "id": "send", "label": "Send", "icon": "send" }
  ],
  "rowColorRules": [
    {
      "when": { "field": "lockInfos.USER", "op": "exists" },
      "background": "#ebebeb",
      "label": "locked"
    }
  ],
  "columns": [
    { "field": "status", "headerName": "Status", "type": "status", "width": 20, "sortable": true, "filter": true, "display": "dot" },
    { "field": "headline", "headerName": "Title", "type": "headline", "flex": 5, "minWidth": 260, "sortable": true, "filter": true },
    { "field": "type", "headerName": "Type", "type": "typeIcon", "width": 90, "sortable": true, "filter": true, "iconOnly": false },
    { "field": "versionInfo.createFamilyTime", "headerName": "Created", "type": "dateUser", "width": 160, "sortable": true,
      "userField": "versionInfo.createFamilyUserRef.userId", "userAliasField": "versionInfo.createFamilyUserRef.alias" },
    { "field": "lockInfos.USER.locked", "headerName": "Locked", "type": "dateUser", "width": 160, "sortable": false,
      "userField": "lockInfos.USER.userUpdateRef.userId", "userAliasField": "lockInfos.USER.userUpdateRef.userName" },
    { "field": "versionInfo.updateVersionTime", "headerName": "Updated", "type": "dateUser", "width": 160, "sortable": true,
      "userField": "versionInfo.updateVersionUserRef.userId", "userAliasField": "versionInfo.updateVersionUserRef.alias" },
    { "field": "publishInfos", "headerName": "Publication", "type": "publication", "width": 110,
      "publications": [
        { "id": "TheGlobe", "icon": "globe", "label": "The Globe" },
        { "id": "SportsArena", "icon": "trophy", "label": "Sports Arena" },
        { "id": "NextFrontier", "icon": "rocket", "label": "Next Frontier" }
      ]
    },
    { "field": "actions", "headerName": "", "type": "actions", "width": 90 }
  ]
}
