{
  "title": "Articoli",
  "demoData": "adn-search-results.json",
  "pollIntervalMs": 20000,
  "workfolderTypes": [
    "article", "wirestory", "wirestory/extcontributions", "wirestory/afpwirestory",
    "article/flash", "article/longform", "article/poll", "hero"
  ],
  "locales": {
    "loading": "Caricamento articoli…",
    "refresh": "Aggiorna",
    "teaser": "Teaser:",
    "unlock": "Sblocca",
    "notPublished": "Non pubblicato",
    "noWorkfolders": "Nessuna cartella disponibile",
    "actions": "Azioni",
    "selectWorkspace": "Seleziona cartella"
  },
  "fields": [
    { "key": "headline", "source": "title" },
    { "key": "summary", "source": "summary" },
    { "key": "type", "derived": "typeLabel" },
    { "key": "date", "source": "updateTs" },
    { "key": "status", "derived": "status" },
    { "key": "statusColor", "derived": "statusColor" },
    { "key": "versionInfo", "source": "versionInfo" },
    { "key": "lockInfos", "source": "lockInfos" },
    { "key": "publishInfos", "source": "publishInfos" },
    { "key": "categories", "source": "categories" },
    { "key": "workFolder", "source": "metadataGroups.eom.sys_attributes_json.workFolder" },
    { "key": "nodeMeta", "source": "nodeMeta" }
  ],
  "icons": {
    "file": "FileText",
    "image": "Image",
    "video": "Video",
    "mic": "Mic",
    "zap": "Zap",
    "rss": "Rss",
    "monitor": "Monitor",
    "copy": "Copy",
    "move": "ArrowRight",
    "send": "Send",
    "pencil": "Pencil",
    "eye": "Eye"
  },
  "typeIcons": {
    "article": "file",
    "article/flash": "zap",
    "gallery": "image",
    "photo": "image",
    "video": "video",
    "audio": "mic"
  },
  "actions": [
    {
      "id": "openInEdit", "label": "Apri in modifica", "icon": "pencil",
      "actionType": "open", "readonly": false, "placement": "inline"
    },
    {
      "id": "openInPreview", "label": "Anteprima", "icon": "eye",
      "actionType": "open", "readonly": true, "placement": "inline"
    },
    {
      "id": "copy-wire", "label": "Copia in Wire", "icon": "rss",
      "actionType": "moveToWorkspace", "workspaceFilter": "Wire",
      "showWhen": { "field": "workFolder", "op": "contains", "value": "/Web" }
    },
    {
      "id": "copy-web", "label": "Copia in Web", "icon": "monitor",
      "actionType": "moveToWorkspace", "workspaceFilter": "Web",
      "showWhen": { "field": "workFolder", "op": "contains", "value": "/Wire" }
    }
  ],
  "rowColorRules": [
    {
      "when": { "field": "typeName", "op": "eq", "value": "article/flash" },
      "background": "#fef9c3",
      "label": "flash"
    }
  ],
  "columns": [
    {
      "field": "status", "headerName": "Stato", "type": "status",
      "width": 20, "sortable": true, "filter": true, "display": "dot"
    },
    {
      "field": "headline", "headerName": "Titolo", "type": "title",
      "flex": 4, "minWidth": 200, "sortable": true, "filter": true, "showTeaser": true
    },
    {
      "field": "publishInfos", "headerName": "Info", "type": "extendedInfo", "width": 100,
      "showTypeIcon": true, "typeIconChip": false, "showLockerInfo": true,
      "icons": [
        { "icon": "rss",     "label": "Wire", "condition": { "field": "publishInfos.Wire.liveFirstPublicationDate", "op": "exists" } },
        { "icon": "monitor", "label": "Web",  "condition": { "field": "publishInfos.Web.liveFirstPublicationDate",  "op": "exists" } }
      ]
    },
    {
      "field": "publishInfos", "headerName": "Categoria", "type": "section",
      "site": "TheGlobe", "width": 120, "sortable": false,
      "colors": [
        { "match": "football",     "background": "#dcfce7", "color": "#15803d" },
        { "match": "tennis",       "background": "#dcfce7", "color": "#15803d" },
        { "match": "golf",         "background": "#dcfce7", "color": "#15803d" },
        { "match": "nba",          "background": "#dcfce7", "color": "#15803d" },
        { "match": "serie",        "background": "#dcfce7", "color": "#15803d" },
        { "match": "fighting",     "background": "#fee2e2", "color": "#b91c1c" },
        { "match": "space",        "background": "#ede9fe", "color": "#6d28d9" },
        { "match": "ai",           "background": "#dbeafe", "color": "#1d4ed8" },
        { "match": "earth",        "background": "#ccfbf1", "color": "#0f766e" },
        { "match": "business",     "background": "#fef9c3", "color": "#854d0e" },
        { "match": "economy",      "background": "#fef9c3", "color": "#854d0e" },
        { "match": "culture",      "background": "#fce7f3", "color": "#be185d" },
        { "match": "books",        "background": "#fce7f3", "color": "#be185d" },
        { "match": "tv",           "background": "#fce7f3", "color": "#be185d" },
        { "match": "games",        "background": "#f3e8ff", "color": "#7e22ce" },
        { "match": "news",         "background": "#f1f5f9", "color": "#475569" },
        { "match": "north",        "background": "#f1f5f9", "color": "#475569" },
        {                          "background": "#f1f5f9", "color": "#64748b" }
      ]
    },
    {
      "field": "versionInfo.createFamilyTime", "headerName": "Creato", "type": "dateUser",
      "width": 150, "sortable": true, "datePattern": "dd/MM/yyyy HH:mm",
      "userField": "versionInfo.createFamilyUserRef.userId",
      "userAliasField": "versionInfo.createFamilyUserRef.alias"
    },
    {
      "field": "versionInfo.updateVersionTime", "headerName": "Ultima Modifica", "type": "dateUser",
      "width": 150, "sortable": true, "datePattern": "dd/MM/yyyy HH:mm",
      "userField": "versionInfo.updateVersionUserRef.userId",
      "userAliasField": "versionInfo.updateVersionUserRef.alias"
    },
    { "field": "actions", "headerName": "", "type": "actions", "width": 120 }
  ]
}
