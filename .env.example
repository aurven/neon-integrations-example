# ACTIVE NEON ENVIRONMENT
# DEMO Configuration
NEON_BO_URL=https://your-demo-neon-bo.eks-dev.dev.eidosmedia.io
NEON_BO_APIKEY=your_neon_bo_api_key_16chars
NEON_FO_APIKEY=your_neon_fo_api_key_16chars
NEON_APP_URL=https://your-demo-neon-app.eks-dev.dev.eidosmedia.io

# Front Office Site URLs
# Format: NEON_FO_<SITENAME>_<ENVIRONMENT>_URL
NEON_FO_THEGLOBE_LIVE_URL=https://your-site.example.io
NEON_FO_THEGLOBE_PREVIEW_URL=https://your-preview-site.example.io
NEON_FO_THEGLOBE_STAGE_URL=https://your-stage-site.example.io

# NEON Common Authentication
NEON_USERNAME=your.username
NEON_PASSWORD=your_neon_password_here

# Méthode DEMOMEDIA Configuration
EDAPI_SERVER=https://your-swing-poc.demomedia.eidosmedia.io
EDAPI_REST_ENDPOINT=/swing/api/rest
EDAPI_USERNAME=your.username
EDAPI_PASSWORD=your_edapi_password_here
EDAPI_CONNECTIONID=Editorial
EDAPI_DATABASEID=33

# Swing Application Configuration
SWING_HOST=https://your-swing-poc.demomedia.eidosmedia.io

# NEON External API
NEON_EXT_LOCATION=Local
NEON_EXT_APIKEY=12345678-1234-1234-1234-123456789abc

# External API Keys
GUARDIAN_APIKEY=12345678-1234-1234-1234-123456789abc

# AI Content Generation (Social Media Panel)
# The system will try Claude first, then fall back to OpenAI if Claude fails
# At least one of these API keys must be configured for AI post generation
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here_with_more_chars
OPENAI_APIKEY=sk-your_openai_api_key_48chars_here_with_more_chars

# Other External Services
SENDGRID_APIKEY=SG.your_sendgrid_key_22chars.your_sendgrid_secret_43chars_here
DEEPL_APIKEY=12345678-1234-1234-1234-123456789abc:fx
TRELLO_APIKEY=your_trello_api_key_32chars_here
TRELLO_TOKEN=ATTA_your_trello_token_72chars_long_here_with_more_characters

# Media Sources API Keys
PEXELS_APIKEY=your_pexels_api_key_48chars_here_for_stock_photos
YOUTUBE_APIKEY=your_youtube_data_api_v3_key_39chars_here
DAILYMOTION_APIKEY=your_dailymotion_api_key_here
DAILYMOTION_APISECRET=your_dailymotion_api_secret_here

# Email Marketing
MAILJET_APIKEY=your_mailjet_api_key_32chars_here
MAILJET_APISECRET=your_mailjet_secret_key_32chars_here

# Telegram Integration
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopQRSTUVwxyz1234567890
TELEGRAM_CHAT_ID=@your_telegram_bot_username
#TELEGRAM_THEGLOBE_CHAT_ID=-1001234567890
#TELEGRAM_NEXTFRONTIER_CHAT_ID=-1001234567891
#TELEGRAM_SPORTSARENA_CHAT_ID=-1001234567892

# Bluesky Social Media Integration
