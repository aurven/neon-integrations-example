# Server Configuration
PORT=54861
HOST=0.0.0.0
NODE_ENV=development
PROJECT_DOMAIN=https://integrations.neon.com:54861

# For hostname access, change HOST to your desired hostname or IP
# Examples:
# HOST=localhost          # Only local access
# HOST=192.168.1.100      # Specific IP address
# HOST=myapp.local        # Custom hostname (requires DNS/hosts file)

# For HTTPS development:
# 1. Install mkcert: brew install mkcert && sudo mkcert -install
# 2. Generate certificates: mkcert integrations.neon.com localhost 127.0.0.1 ::1
# 3. Move to ssl/: mkdir -p ssl && mv integrations.neon.com+3* ssl/
# 4. Configure DNS with dnsmasq (for *.neon.com wildcard resolution):
#    - brew install dnsmasq
#    - echo "address=/neon.com/127.0.0.1" >> /opt/homebrew/etc/dnsmasq.conf
#    - sudo brew services start dnsmasq
#    - sudo mkdir -p /etc/resolver
#    - echo "nameserver 127.0.0.1" | sudo tee /etc/resolver/neon.com

# POC Environment (Commented - use for testing)
#NEON_BO_URL=https://your-poc-neon-bo.eks-dev.dev.eidosmedia.io
#NEON_BO_APIKEY=your_poc_api_key_base64_encoded==
#NEON_FO_APIKEY=your_poc_fo_api_key_base64_encoded==
