# Server Configuration
PORT=54861
HOST=0.0.0.0
NODE_ENV=development
PROJECT_DOMAIN=https://neon-integrations-example.neon.com:54861

# For hostname access, change HOST to your desired hostname or IP
# Examples:
# HOST=localhost          # Only local access
# HOST=192.168.1.100      # Specific IP address
# HOST=myapp.local        # Custom hostname (requires DNS/hosts file)

# For HTTPS development:
# 1. Install mkcert: brew install mkcert && sudo mkcert -install
# 2. Generate certificates: mkcert neon-integrations-example.neon.com localhost 127.0.0.1 ::1
# 3. Move to ssl/: mkdir -p ssl && mv neon-integrations-example.neon.com+3* ssl/
# 4. Add to /etc/hosts: 127.0.0.1 neon-integrations-example.neon.com

