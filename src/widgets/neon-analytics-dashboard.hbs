<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neon Analytics - Production Metrics Dashboard</title>
    <!-- Panel Bootstrap (inline with dynamic resource loading to avoid path issues when embedded) -->
    <script>(function(w){'use strict';function e(){try{return w.self!==w.top}catch(e){return true}}const m=e(),p=m?'/neon/api/demo-integration':'';w.__PANEL_EMBED_PREFIX__=p;w.__PANEL_IS_EMBEDDED__=m;const l=document.createElement('link');l.rel='stylesheet';l.href=p+'/css/tailwind-panels.css';document.head.appendChild(l);const s=document.createElement('script');s.src=p+'/js/panel-api-helper.js';document.head.appendChild(s)})(window);</script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Detect if embedded and load scripts accordingly
        (function() {
            const isEmbedded = window.self !== window.top;
            const prefix = isEmbedded ? '/neon/api/demo-integration' : '';

            // Load data processing script
            const dataScript = document.createElement('script');
            dataScript.src = prefix + '/js/neon-analytics-data.js';
            document.head.appendChild(dataScript);

            // Load charts script
            const chartsScript = document.createElement('script');
            chartsScript.src = prefix + '/js/neon-analytics-charts.js';
            document.head.appendChild(chartsScript);
        })();
    </script>
    <style>
        /* Modern font stack */
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        /* Neon color variables */
        :root {
            --neon-blue: #2847E2;
            --neon-pink: #F75880;
            --neon-black: #1D1930;
            --neon-white: #FFFFFF;
            --neon-text-primary: #1F2937;
            --neon-text-secondary: #6B7280;
            --neon-border: #E5E7EB;
            --neon-background: #F9FAFB;
        }

        /* Chart containers */
        .chart-container {
            position: relative;
            width: 100%;
            height: 300px;
        }

        .chart-container-small {
            position: relative;
            width: 100%;
            height: 250px;
        }

        .chart-container-medium {
            position: relative;
            width: 100%;
            height: 350px;
        }

        .chart-container-heatmap {
            position: relative;
            width: 100%;
            min-height: 200px;
        }

        /* Live indicator pulse animation */
        @keyframes pulse-live {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .live-indicator {
            animation: pulse-live 2s ease-in-out infinite;
        }

        /* Gradient background */
        .neon-gradient {
            background: linear-gradient(135deg, var(--neon-blue) 0%, var(--neon-pink) 100%);
        }

        /* Heatmap calendar styling */
        .heatmap-container {
            display: grid;
            gap: 3px;
            grid-auto-flow: column;
            justify-content: start;
        }

        .heatmap-day {
            width: 15px;
            height: 15px;
            border-radius: 2px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .heatmap-day:hover {
            transform: scale(1.2);
            border: 2px solid var(--neon-blue);
        }

        /* Metric card hover effect */
        .metric-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(40, 71, 226, 0.1);
            transition: all 0.2s ease;
        }

        /* Loading spinner */
        .spinner {
            border: 3px solid #f3f4f6;
            border-top: 3px solid var(--neon-blue);
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Info icon tooltip */
        .info-icon-container {
            position: relative;
            z-index: 1;
        }

        .info-icon-container:hover {
            z-index: 9999;
        }

        .info-icon-container:hover .info-tooltip {
            display: block !important;
        }

        .info-tooltip {
            animation: fadeIn 0.2s ease-in;
            line-height: 1.5;
            min-width: 280px;
            max-width: 350px;
            white-space: normal;
        }

        .info-tooltip::before {
            content: '';
            position: absolute;
            left: -8px;
            top: 12px;
            width: 0;
            height: 0;
            border-top: 8px solid transparent;
            border-bottom: 8px solid transparent;
            border-right: 8px solid white;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-5px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

