    <script>
        // Global state
        let currentMetric = null;
        let metricsData = null;
        let charts = {};
        const isDemoMode = new URLSearchParams(window.location.search).get('demo') === 'true';

        // Initialize on load
        window.addEventListener('load', function() {
            console.log('Neon Analytics Dashboard initializing...');

            // Show demo badge if in demo mode
            if (isDemoMode) {
                document.getElementById('demo-badge').classList.remove('hidden');
            }

            // Set up metric selector
            const selector = document.getElementById('metric-selector');
            selector.addEventListener('change', handleMetricChange);

            // Pre-select first metric if in demo mode
            if (isDemoMode) {
                selector.value = 'month_worked';
                handleMetricChange();
            }
        });

        async function handleMetricChange() {
            const selector = document.getElementById('metric-selector');
            const metric = selector.value;

            if (!metric) {
                document.getElementById('analytics-content').classList.add('hidden');
                document.getElementById('data-info').textContent = 'Select a metric to view analytics';
                return;
            }

            currentMetric = metric;
            showLoading(true);

            try {
                // Load data (demo or real API)
                const data = await loadMetricsData(metric);
                metricsData = parseNeonMetrics(data);

                // Update UI
                updateDashboard(metricsData);

                // Show content
                document.getElementById('analytics-content').classList.remove('hidden');
                document.getElementById('data-info').textContent = `Loaded: ${metric}`;

            } catch (error) {
                console.error('Error loading metrics:', error);
                document.getElementById('data-info').textContent = 'Error loading data';
                document.getElementById('analytics-content').classList.add('hidden');
            } finally {
                showLoading(false);
            }
        }

        async function loadMetricsData(metric) {
            if (isDemoMode) {
                // Load from static JSON files
                const response = await fetch(`/data/neon-analytics/api-metrics-example-${metric}.json`);
                if (!response.ok) throw new Error('Failed to load demo data');
                return await response.json();
            } else {
                // Load from real API
                const isEmbedded = window.self !== window.top;
                const prefix = isEmbedded ? '/neon/api/demo-integration' : '';
                const response = await fetch(`${prefix}/neon/api/core/metrics/${metric}`);
                if (!response.ok) throw new Error('Failed to load metrics');
                return await response.json();
            }
        }

        function showLoading(show) {
            const spinner = document.getElementById('loading-spinner');
            if (show) {
                spinner.classList.remove('hidden');
            } else {
                spinner.classList.add('hidden');
            }
        }

        function updateDashboard(data) {
            console.log('Updating dashboard with data:', data);

            // Update metrics cards
            document.getElementById('metric-total').textContent = data.totalItems.toLocaleString();
            document.getElementById('metric-types').textContent = data.uniqueTypes;
            document.getElementById('metric-users').textContent = data.uniqueUsers;
            document.getElementById('metric-avg').textContent = data.avgPerUser.toFixed(1);
            document.getElementById('metric-peak-day').textContent = data.peakDay.date;
            document.getElementById('metric-peak-count').textContent = `${data.peakDay.count} items`;
            document.getElementById('metric-folders').textContent = data.uniqueFolders;

            // Destroy existing charts
            Object.values(charts).forEach(chart => {
                if (chart && typeof chart.destroy === 'function') {
                    chart.destroy();
                }
            });
            charts = {};

            // Determine which charts to show based on metric type
            const isActiveUsers = currentMetric.includes('active_users');
            const hasTypes = data.types && data.types.length > 0;
            const hasUsers = data.users && data.users.length > 0;
            const hasWorkfolders = data.workfolders && data.workfolders.length > 0;
            const hasEndpoints = data.endpoints && data.endpoints.length > 0;

            // Show/hide containers
            const typesContainer = document.getElementById('types-container');
            const usersContainer = document.getElementById('users-container');
            const workfoldersContainer = document.getElementById('workfolders-container');
            const endpointsContainer = document.getElementById('endpoints-container');

            if (typesContainer) typesContainer.style.display = hasTypes ? 'block' : 'none';
            if (usersContainer) usersContainer.style.display = hasUsers ? 'block' : 'none';
            if (workfoldersContainer) workfoldersContainer.style.display = hasWorkfolders ? 'block' : 'none';
            if (endpointsContainer) endpointsContainer.style.display = hasEndpoints ? 'block' : 'none';

            // Initialize charts (check if functions exist)
            if (typeof initTimelineChart === 'function') {
                charts.timeline = initTimelineChart(data);
            }

            if (hasTypes && typeof initTypesChart === 'function') {
                charts.types = initTypesChart(data);
            }

            if (hasUsers && typeof initUsersChart === 'function') {
                charts.users = initUsersChart(data);
            }

            if (typeof initHourlyChart === 'function') {
                charts.hourly = initHourlyChart(data);
            }

            if (hasWorkfolders && typeof initWorkfoldersChart === 'function') {
                charts.workfolders = initWorkfoldersChart(data);
            }

            if (hasEndpoints && typeof initEndpointsChart === 'function') {
                charts.endpoints = initEndpointsChart(data);
            }

            // Render heatmap
            if (typeof renderCalendarHeatmap === 'function') {
                renderCalendarHeatmap(data);
            }

            console.log('Dashboard updated successfully');
        }

        console.log('Neon Analytics Dashboard script loaded');
    </script>
</body>

</html>
