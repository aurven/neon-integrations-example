.nti-dropdown-item:hover, .nti-dropdown-item.nti-highlighted { background: #eef2fe; color: #2847E2; }
.nti-dropdown-empty { padding: 0.5rem 0.75rem; font-size: 0.8125rem; color: #9ca3af; font-style: italic; }
</style>

<!-- Container elements -->
<div id="topics-tags"></div>
<div id="geography-tags"></div>

<script>
// --- Paste the NeonTagsInput class here ---
// (full class code from the mockup page)

// --- Initialize ---
// \$metadataXml is provided by Neon Object Panel
var topicsTags = new NeonTagsInput({
    container: document.getElementById('topics-tags'),
    familyId: 'topic',
    xmlParent: 'Topics',       // reads/writes <CustomTags><Topics><Topic>...</Topic></Topics>
    xmlChild: 'Topic',
    apiBase: '/neon/api/demo-integration/tags',
    \\$metadataXml: \\$metadataXml,
    label: 'Topics'
});

var geoTags = new NeonTagsInput({
    container: document.getElementById('geography-tags'),
    familyId: 'geo',
    xmlParent: 'Geography',    // reads/writes <CustomTags><Geography><Place>...</Place></Geography>
    xmlChild: 'Place',
