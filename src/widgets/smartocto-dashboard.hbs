    <script>
        // ============================================================
        // DATE UTILITIES - Calculate current week range
        // ============================================================
        function getWeekRange() {
            const now = new Date();
            const currentDay = now.getDay(); // 0 = Sunday, 1 = Monday, etc.
            const diff = currentDay === 0 ? -6 : 1 - currentDay; // Adjust to get Monday

            const monday = new Date(now);
            monday.setDate(now.getDate() + diff);
            monday.setHours(0, 0, 0, 0);

            const sunday = new Date(monday);
            sunday.setDate(monday.getDate() + 6);
            sunday.setHours(23, 59, 59, 999);

            return { monday, sunday, currentDayOfWeek: currentDay === 0 ? 7 : currentDay };
        }

        function formatDateRange(monday, sunday) {
            const options = { month: 'short', day: 'numeric' };
            const start = monday.toLocaleDateString('en-US', options);
            const end = sunday.toLocaleDateString('en-US', options);
            return `${start} - ${end}, ${monday.getFullYear()}`;
        }

        // ============================================================
        // DATA GENERATION - Create weekly dashboard data
        // ============================================================
        function generateWeeklyData() {
            const { monday, sunday, currentDayOfWeek } = getWeekRange();
            const weekDays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

            // Generate seeded random data for consistency
            const seed = monday.getTime();
            function seededRandom(offset) {
                const x = Math.sin(seed + offset) * 10000;
                return x - Math.floor(x);
            }

            // Weekly metrics (aggregate)
            const totalArticles = Math.floor(seededRandom(1) * 30) + 50; // 50-80 articles
            const totalViews = Math.floor(seededRandom(2) * 500000) + 750000; // 750k-1.25M views
            const avgAttention = Math.floor(seededRandom(3) * 20) + 70; // 70-90
            const avgReadRatio = (seededRandom(4) * 30 + 60).toFixed(1); // 60-90%
            const totalEngagementHours = Math.floor(seededRandom(5) * 2000) + 3000; // 3000-5000 hours
            const totalShares = Math.floor(seededRandom(6) * 20000) + 30000; // 30k-50k shares

            // Trends vs last week (random -20% to +30%)
            const trends = {
                articles: ((seededRandom(10) * 50) - 20).toFixed(1),
                views: ((seededRandom(11) * 50) - 20).toFixed(1),
                attention: ((seededRandom(12) * 50) - 20).toFixed(1),
                readRatio: ((seededRandom(13) * 50) - 20).toFixed(1),
                engagement: ((seededRandom(14) * 50) - 20).toFixed(1),
                shares: ((seededRandom(15) * 50) - 20).toFixed(1)
            };

            // Daily article counts (only up to current day)
            const dailyArticles = weekDays.map((day, idx) => {
                if (idx >= currentDayOfWeek) return 0;
                return Math.floor(seededRandom(20 + idx) * 15) + 5; // 5-20 articles per day
            });

            // Daily views
            const dailyViews = weekDays.map((day, idx) => {
                if (idx >= currentDayOfWeek) return 0;
                return Math.floor(seededRandom(30 + idx) * 150000) + 100000; // 100k-250k per day
            });

            // Traffic sources (weekly total)
            const trafficSources = {
                'Direct': Math.floor(seededRandom(40) * 100000) + 200000,
                'Social Media': Math.floor(seededRandom(41) * 150000) + 250000,
                'Search': Math.floor(seededRandom(42) * 120000) + 180000,
                'Referrals': Math.floor(seededRandom(43) * 80000) + 100000,
                'Email': Math.floor(seededRandom(44) * 50000) + 50000
            };

            // Device distribution
            const devices = {
                'Desktop': Math.floor(seededRandom(50) * 200000) + 300000,
                'Mobile': Math.floor(seededRandom(51) * 300000) + 400000,
                'Tablet': Math.floor(seededRandom(52) * 80000) + 50000
            };

            // Hourly engagement pattern (24 hours)
            const hourlyEngagement = Array.from({length: 24}, (_, i) => {
                // Simulate peak hours (7-10am, 12-2pm, 6-10pm)
                let base = 1000;
                if ((i >= 7 && i <= 10) || (i >= 12 && i <= 14) || (i >= 18 && i <= 22)) {
                    base = 5000;
                }
                return Math.floor(seededRandom(60 + i) * base) + base;
            });

            // Top 10 articles
            const topArticles = Array.from({length: 10}, (_, i) => ({
                rank: i + 1,
                title: [
                    'Breaking: Major Policy Announcement Impacts Markets',
                    'Exclusive Interview with Industry Leader',
                    'Analysis: Trends Shaping the Future',
                    'Local Hero Makes Global Impact',
                    'Technology Breakthrough Changes Everything',
                    'Sports: Underdog Team Achieves Victory',
                    'Culture: New Exhibition Opens to Critical Acclaim',
                    'Health: Breakthrough Research Published',
                    'Business: Startup Secures Major Funding',
                    'Environment: Conservation Efforts Show Results'
                ][i],
                attention: Math.floor(seededRandom(70 + i) * 20) + (80 - i * 5), // Descending scores
                views: Math.floor(seededRandom(80 + i) * 50000) + (100000 - i * 8000),
                readRatio: (seededRandom(90 + i) * 30 + 65).toFixed(1),
                shares: Math.floor(seededRandom(100 + i) * 5000) + (10000 - i * 800),
                publishedDaysAgo: Math.floor(seededRandom(110 + i) * currentDayOfWeek)
            }));

            // AI Insights
            const insights = [
                {
                    priority: 'high',
                    text: 'Peak engagement occurs at 8-10am and 7-9pm. Schedule high-value content during these windows.'
                },
                {
                    priority: 'high',
                    text: `Mobile traffic accounts for ${((devices.Mobile / totalViews) * 100).toFixed(0)}% of views. Optimize mobile reading experience.`
                },
                {
                    priority: 'medium',
                    text: `Average Attention Score is ${avgAttention}/100. Consider A/B testing headlines to improve engagement.`
                },
                {
                    priority: 'medium',
                    text: 'Social media drives significant traffic. Increase posting frequency on high-performing platforms.'
                },
                {
                    priority: 'low',
                    text: 'Articles published on Tuesday show 15% higher engagement. Consider adjusting editorial calendar.'
                },
                {
                    priority: 'low',
                    text: 'Content with video elements receives 2x more shares. Incorporate more multimedia content.'
                }
            ];

            return {
                weekRange: formatDateRange(monday, sunday),
                currentDayOfWeek,
                totalArticles,
                totalViews,
                avgAttention,
                avgReadRatio,
                totalEngagementHours,
                totalShares,
                trends,
                weekDays,
                dailyArticles,
                dailyViews,
                trafficSources,
                devices,
                hourlyEngagement,
                topArticles,
                insights
            };
        }

        // ============================================================
        // UI UPDATE FUNCTIONS
        // ============================================================
        function updateMetrics(data) {
            document.getElementById('week-range').textContent = data.weekRange;
            document.getElementById('current-day-number').textContent = data.currentDayOfWeek;

            document.getElementById('metric-articles').textContent = data.totalArticles;
            document.getElementById('metric-views').textContent = data.totalViews.toLocaleString();
            document.getElementById('metric-attention').textContent = data.avgAttention;
            document.getElementById('metric-readratio').textContent = data.avgReadRatio + '%';
            document.getElementById('metric-engagement').textContent = (data.totalEngagementHours / 1000).toFixed(1) + 'k hrs';
            document.getElementById('metric-shares').textContent = data.totalShares.toLocaleString();

            // Update trends
            updateTrend('articles-trend', data.trends.articles);
            updateTrend('views-trend', data.trends.views);
            updateTrend('attention-trend', data.trends.attention);
            updateTrend('readratio-trend', data.trends.readRatio);
            updateTrend('engagement-trend', data.trends.engagement);
            updateTrend('shares-trend', data.trends.shares);
        }

        function updateTrend(elementId, trendValue) {
            const element = document.getElementById(elementId);
            const value = parseFloat(trendValue);
            const icon = value >= 0 ? '↑' : '↓';
            const color = value >= 0 ? 'text-green-600' : 'text-red-600';
            element.textContent = `${icon} ${Math.abs(value)}%`;
            element.className = `text-xs font-semibold ${color}`;
        }

        function updateArticlesTable(articles) {
            const tbody = document.getElementById('articles-table-body');
            tbody.innerHTML = '';

            articles.forEach(article => {
                const scoreClass = article.attention >= 85 ? 'score-excellent' :
                                   article.attention >= 75 ? 'score-good' :
                                   article.attention >= 65 ? 'score-fair' : 'score-poor';

                const daysAgoText = article.publishedDaysAgo === 0 ? 'Today' :
                                   article.publishedDaysAgo === 1 ? '1 day ago' :
                                   `${article.publishedDaysAgo} days ago`;

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="font-semibold text-gray-700">${article.rank}</td>
                    <td class="font-medium text-gray-900">${article.title}</td>
                    <td><span class="inline-block px-2 py-1 rounded text-xs font-bold ${scoreClass}">${article.attention}</span></td>
                    <td class="text-gray-700">${article.views.toLocaleString()}</td>
                    <td class="text-gray-700">${article.readRatio}%</td>
                    <td class="text-gray-700">${article.shares.toLocaleString()}</td>
                    <td class="text-gray-500 text-xs">${daysAgoText}</td>
                `;
                tbody.appendChild(row);
            });
        }

        function updateInsights(insights) {
            const container = document.getElementById('insights-container');
            container.innerHTML = '';

            insights.forEach(insight => {
                const priorityColors = {
                    high: 'bg-red-100 text-red-700 border-red-300',
                    medium: 'bg-orange-100 text-orange-700 border-orange-300',
                    low: 'bg-blue-100 text-blue-700 border-blue-300'
                };

                const card = document.createElement('div');
                card.className = 'recommendation-card bg-white rounded-lg p-4 border border-gray-200';
                card.innerHTML = `
                    <div class="flex items-start space-x-2">
                        <div class="flex-shrink-0">
                            <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold ${priorityColors[insight.priority]}">${insight.priority.toUpperCase()}</span>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-gray-700">${insight.text}</p>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // ============================================================
        // CHART INITIALIZATION
        // ============================================================
        function initCharts(data) {
            // Weekly Trend Chart (Dual axis: Articles + Views)
            const weeklyCtx = document.getElementById('weekly-trend-chart').getContext('2d');
            new Chart(weeklyCtx, {
                type: 'bar',
                data: {
                    labels: data.weekDays,
                    datasets: [
                        {
                            label: 'Articles Published',
                            data: data.dailyArticles,
                            backgroundColor: 'rgba(124, 58, 237, 0.6)',
                            borderColor: 'rgba(124, 58, 237, 1)',
                            borderWidth: 2,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Page Views',
                            data: data.dailyViews,
                            type: 'line',
                            backgroundColor: 'rgba(20, 184, 166, 0.1)',
                            borderColor: 'rgba(20, 184, 166, 1)',
                            borderWidth: 3,
                            tension: 0.4,
                            fill: true,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        }
                    },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: {
                                display: true,
                                text: 'Articles'
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            title: {
                                display: true,
                                text: 'Views'
                            },
                            grid: {
                                drawOnChartArea: false
                            }
                        }
                    }
                }
            });

            // Traffic Sources Chart (Donut)
            const trafficCtx = document.getElementById('traffic-chart').getContext('2d');
            new Chart(trafficCtx, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(data.trafficSources),
                    datasets: [{
                        data: Object.values(data.trafficSources),
                        backgroundColor: [
                            'rgba(124, 58, 237, 0.8)',
                            'rgba(20, 184, 166, 0.8)',
                            'rgba(59, 130, 246, 0.8)',
                            'rgba(16, 185, 129, 0.8)',
                            'rgba(245, 158, 11, 0.8)'
                        ],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right'
                        }
                    }
                }
            });

            // Device Chart (Pie)
            const deviceCtx = document.getElementById('device-chart').getContext('2d');
            new Chart(deviceCtx, {
                type: 'pie',
                data: {
                    labels: Object.keys(data.devices),
                    datasets: [{
                        data: Object.values(data.devices),
                        backgroundColor: [
                            'rgba(124, 58, 237, 0.8)',
                            'rgba(20, 184, 166, 0.8)',
                            'rgba(59, 130, 246, 0.8)'
                        ],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right'
                        }
                    }
                }
            });

            // Hourly Engagement Chart (Line)
            const hourlyCtx = document.getElementById('hourly-chart').getContext('2d');
            new Chart(hourlyCtx, {
                type: 'line',
                data: {
                    labels: Array.from({length: 24}, (_, i) => `${i}:00`),
                    datasets: [{
                        label: 'Engagement',
                        data: data.hourlyEngagement,
                        backgroundColor: 'rgba(124, 58, 237, 0.1)',
                        borderColor: 'rgba(124, 58, 237, 1)',
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: 'rgba(124, 58, 237, 1)',
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Views'
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Hour of Day'
                            }
                        }
                    }
                }
            });

            // Top Articles Chart (Horizontal Bar)
            const topArticlesCtx = document.getElementById('top-articles-chart').getContext('2d');
            new Chart(topArticlesCtx, {
                type: 'bar',
                data: {
                    labels: data.topArticles.map(a => `#${a.rank} ${a.title.substring(0, 40)}...`),
                    datasets: [{
                        label: 'Attention Score',
                        data: data.topArticles.map(a => a.attention),
                        backgroundColor: data.topArticles.map(a => {
                            if (a.attention >= 85) return 'rgba(124, 58, 237, 0.8)';
                            if (a.attention >= 75) return 'rgba(16, 185, 129, 0.8)';
                            if (a.attention >= 65) return 'rgba(245, 158, 11, 0.8)';
                            return 'rgba(239, 68, 68, 0.8)';
                        }),
                        borderWidth: 0
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            max: 100,
                            title: {
                                display: true,
                                text: 'Attention Score'
                            }
                        }
                    }
                }
            });
        }

        // ============================================================
        // INITIALIZE DASHBOARD
        // ============================================================
        window.addEventListener('load', function() {
            console.log('SmartOcto Dashboard initializing...');

            const dashboardData = generateWeeklyData();

            updateMetrics(dashboardData);
            updateArticlesTable(dashboardData.topArticles);
            updateInsights(dashboardData.insights);
            initCharts(dashboardData);

            console.log('SmartOcto Dashboard loaded with data:', dashboardData);
        });
    </script>
</body>

</html>
