    <style>
        /* Modern font stack */
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        /* SmartOcto color variables */
        :root {
            --so-purple: #7C3AED;
            --so-teal: #14B8A6;
            --so-blue: #3B82F6;
            --so-green: #10B981;
            --so-orange: #F59E0B;
            --so-red: #EF4444;
            --so-text-primary: #1F2937;
            --so-text-secondary: #6B7280;
            --so-border: #E5E7EB;
            --so-background: #F9FAFB;
        }

        /* Chart containers */
        .chart-container {
            position: relative;
            width: 100%;
            height: 300px;
        }

        .chart-container-small {
            position: relative;
            width: 100%;
            height: 250px;
        }

        .chart-container-medium {
            position: relative;
            width: 100%;
            height: 350px;
        }

        /* Live indicator pulse animation */
        @keyframes pulse-live {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .live-indicator {
            animation: pulse-live 2s ease-in-out infinite;
        }

        /* Score gauge styling */
        .score-gauge {
            background: linear-gradient(90deg, #EF4444 0%, #F59E0B 25%, #14B8A6 50%, #10B981 75%, #7C3AED 100%);
        }

        /* Table styling */
        .articles-table {
            font-size: 0.875rem;
        }

        .articles-table thead > tr {
            background: linear-gradient(135deg, #7C3AED 0%, #14B8A6 100%);
        }

        .articles-table th {
            color: white;
            font-weight: 600;
            padding: 0.75rem;
            text-align: left;
        }

        .articles-table td {
            padding: 0.75rem;
            border-bottom: 1px solid var(--so-border);
        }

        .articles-table tbody tr:hover {
            background-color: #F9FAFB;
        }

        /* Recommendation card hover effect */
        .recommendation-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            transition: all 0.2s ease;
        }

        /* Score badge colors */
        .score-excellent { background-color: #7C3AED; color: white; }
        .score-good { background-color: #10B981; color: white; }
        .score-fair { background-color: #F59E0B; color: white; }
        .score-poor { background-color: #EF4444; color: white; }
    </style>
</head>

