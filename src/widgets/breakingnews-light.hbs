<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{seo.title}}</title>
    <link rel="icon" href="/assets/favicon.ico">
    <link rel="canonical" href="{{seo.url}}">
    <meta name="description" content="{{seo.description}}">
    <meta property="og:title" content="{{seo.title}} - Breaking News Publisher">
    <meta property="og:type" content="article">
    <meta property="og:url" content="{{seo.url}}">
    <meta property="og:description" content="{{seo.description}}">
    <meta property="og:image" content="{{seo.image}}">
    <meta name="twitter:card" content="summary">
    <link rel="stylesheet" href="/css/tailwind-panels.css">
    <link rel="stylesheet" href="/neon/api/demo-integration/css/tailwind-panels.css">
    <link rel="stylesheet" href="/css/breakingnews-widget.css">
    <link rel="stylesheet" href="/neon/api/demo-integration/css/breakingnews-widget.css">
    <script src="/js/panel-api-helper.js"></script>
    <script src="/neon/api/demo-integration/js/panel-api-helper.js"></script>
</head>

<body>
    <div id="bn-container" class="bn-container">

        <!-- Header (hidden when embedded) -->
        <div id="bn-header" class="bn-header">
            <div class="bn-header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
            </div>
            <div>
                <p class="bn-header-title">Breaking News Publisher</p>
                <p class="bn-header-subtitle">Create and publish breaking news articles instantly</p>
            </div>
        </div>

        <!-- Form -->
        <div id="bn-form-card" class="bn-card">
            <form id="bn-form">
                <div class="bn-form-group">
                    <label class="bn-label" for="bn-headline">
                        Headline <span class="bn-required">*</span>
                    </label>
                    <input
                        class="bn-input"
                        type="text"
                        id="bn-headline"
                        name="headline"
                        required
                        maxlength="255"
                        placeholder="Enter breaking news headline"
                    >
                </div>

                <div class="bn-form-group">
                    <label class="bn-label" for="bn-summary">Summary</label>
                    <textarea
                        class="bn-textarea"
                        id="bn-summary"
                        name="summary"
                        rows="3"
                        maxlength="500"
                        placeholder="Enter a brief summary (optional)"
                    ></textarea>
                </div>

                <div class="bn-form-group">
                    <label class="bn-label" for="bn-body">Body</label>
                    <textarea
                        class="bn-textarea"
                        id="bn-body"
                        name="body"
                        rows="6"
                        placeholder="Enter the main content of the breaking news (optional)"
                    ></textarea>
                </div>

                <button type="submit" id="bn-publish-btn" class="bn-btn bn-btn-primary">
                    Publish Breaking News
                </button>
            </form>
        </div>

        <!-- Result card (progress / success / error) -->
        <div id="bn-result-card" class="bn-result-card">
            <div id="bn-result-message" class="bn-result-message"></div>
            <div id="bn-result-buttons" class="bn-result-buttons"></div>
        </div>

    </div>

    <script>
        // ── Embedding detection ──────────────────────────────────────────────
        const bnEmbedded = (typeof PanelAPI !== 'undefined') ? PanelAPI.isEmbedded() : (window.self !== window.top);

        if (bnEmbedded) {
            document.getElementById('bn-header').classList.add('hidden');
            document.getElementById('bn-container').classList.add('bn-embedded');
            document.getElementById('bn-form-card').classList.add('bn-embedded');
        }

        // ── SVG icon helpers ─────────────────────────────────────────────────
        function bnSpinnerSvg() {
            return `<svg class="bn-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" width="18" height="18">
                <circle style="opacity:.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>`;
        }

        function bnCheckSvg() {
            return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
            </svg>`;
        }

        function bnCrossSvg() {
            return `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
            </svg>`;
        }

        // ── Result card helpers ──────────────────────────────────────────────
        const bnResultCard = document.getElementById('bn-result-card');
        const bnResultMessage = document.getElementById('bn-result-message');
        const bnResultButtons = document.getElementById('bn-result-buttons');

        function bnShowResult(state, messageHtml, buttons = []) {
            bnResultCard.className = `bn-result-card bn-visible${state ? ' bn-' + state : ''}`;
            bnResultMessage.className = `bn-result-message${state ? ' bn-' + state : ''}`;
            bnResultMessage.innerHTML = messageHtml;

            bnResultButtons.innerHTML = '';
            buttons.forEach(({ label, style, onClick }) => {
                const btn = document.createElement('button');
                btn.className = `bn-btn bn-btn-${style || 'secondary'}`;
                btn.innerHTML = label;
                btn.onclick = onClick;
                bnResultButtons.appendChild(btn);
            });
        }

        function bnHideResult() {
            bnResultCard.className = 'bn-result-card';
        }

        // ── Form show/hide ───────────────────────────────────────────────────
        const bnFormCard = document.getElementById('bn-form-card');
        const bnPublishBtn = document.getElementById('bn-publish-btn');

        function bnShowForm() {
            bnFormCard.style.display = '';
            bnPublishBtn.disabled = false;
            bnPublishBtn.innerHTML = 'Publish Breaking News';
        }

        function bnHideForm() {
            bnFormCard.style.display = 'none';
        }

        // ── Form submission ──────────────────────────────────────────────────
        document.getElementById('bn-form').addEventListener('submit', async function (e) {
            e.preventDefault();

            const headline = document.getElementById('bn-headline').value.trim();
            const summary = document.getElementById('bn-summary').value.trim();
            const body = document.getElementById('bn-body').value.trim();

            if (!headline) {
                alert('Headline is required.');
                return;
            }

            bnPublishBtn.disabled = true;
            bnPublishBtn.innerHTML = `${bnSpinnerSvg()} Publishing...`;

            bnHideForm();
            bnShowResult('', `${bnSpinnerSvg()} Publishing breaking news to Neon...`);

            try {
                const formData = new URLSearchParams();
                formData.append('headline', headline);
                formData.append('summary', summary);
                formData.append('body', body);

                const endpoint = '/widgets/breakingnews/publish';
                let response;

                if (typeof PanelAPI !== 'undefined') {
                    response = await PanelAPI.apiCall(endpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: formData
                    });
                } else {
                    response = await fetch(endpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: formData
                    });
                }

                const result = await response.json();

                if (response.ok) {
                    const familyRef = result.neon && result.neon[0];
                    const neonAppUrl = '{{neonAppUrl}}';

                    bnShowResult('success', `${bnCheckSvg()} Breaking news published <strong>successfully</strong>!`, [
                        familyRef && neonAppUrl ? {
                            label: 'Open in Neon',
                            style: 'success',
                            onClick: () => window.open(`${neonAppUrl}/neon/app/neon.html#open/${familyRef}`)
                        } : null,
                        {
                            label: 'Publish Another',
                            style: 'secondary',
                            onClick: () => {
                                document.getElementById('bn-form').reset();
                                bnHideResult();
                                bnShowForm();
                            }
                        }
                    ].filter(Boolean));
                } else {
                    bnShowResult('error', `${bnCrossSvg()} Failed to publish: ${result.message || 'Unknown error'}`, [
                        {
                            label: 'Try Again',
                            style: 'danger',
                            onClick: () => { bnHideResult(); bnShowForm(); }
                        }
                    ]);
                }
            } catch (err) {
                console.error('Error publishing breaking news:', err);
                bnShowResult('error', `${bnCrossSvg()} Network error: ${err.message}`, [
                    {
                        label: 'Try Again',
                        style: 'danger',
                        onClick: () => { bnHideResult(); bnShowForm(); }
                    }
                ]);
            }
        });
    </script>
</body>

</html>
