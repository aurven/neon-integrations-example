                color: '#E4405F',
                maxLength: 2200,
                imageRatio: '1:1' // Square
            },
            threads: {
                name: 'Threads',
                icon: '<svg aria-label="Threads" viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg"><path class="x19hqcy" d="M141.537 88.9883C140.71 88.5919 139.87 88.2104 139.019 87.8451C137.537 60.5382 122.616 44.905 97.5619 44.745C97.4484 44.7443 97.3355 44.7443 97.222 44.7443C82.2364 44.7443 69.7731 51.1409 62.102 62.7807L75.881 72.2328C81.6116 63.5383 90.6052 61.6848 97.2286 61.6848C97.3051 61.6848 97.3819 61.6848 97.4576 61.6855C105.707 61.7381 111.932 64.1366 115.961 68.814C118.893 72.2193 120.854 76.925 121.825 82.8638C114.511 81.6207 106.601 81.2385 98.145 81.7233C74.3247 83.0954 59.0111 96.9879 60.0396 116.292C60.5615 126.084 65.4397 134.508 73.775 140.011C80.8224 144.663 89.899 146.938 99.3323 146.423C111.79 145.74 121.563 140.987 128.381 132.296C133.559 125.696 136.834 117.143 138.28 106.366C144.217 109.949 148.617 114.664 151.047 120.332C155.179 129.967 155.42 145.8 142.501 158.708C131.182 170.016 117.576 174.908 97.0135 175.059C74.2042 174.89 56.9538 167.575 45.7381 153.317C35.2355 139.966 29.8077 120.682 29.6052 96C29.8077 71.3178 35.2355 52.0336 45.7381 38.6827C56.9538 24.4249 74.2039 17.11 97.0132 16.9405C119.988 17.1113 137.539 24.4614 149.184 38.788C154.894 45.8136 159.199 54.6488 162.037 64.9503L178.184 60.6422C174.744 47.9622 169.331 37.0357 161.965 27.974C147.036 9.60668 125.202 0.195148 97.0695 0H96.9569C68.8816 0.19447 47.2921 9.6418 32.7883 28.0793C19.8819 44.4864 13.2244 67.3157 13.0007 95.9325L13 96L13.0007 96.0675C13.2244 124.684 19.8819 147.514 32.7883 163.921C47.2921 182.358 68.8816 191.806 96.9569 192H97.0695C122.03 191.827 139.624 185.292 154.118 170.811C173.081 151.866 172.51 128.119 166.26 113.541C161.776 103.087 153.227 94.5962 141.537 88.9883ZM98.4405 129.507C88.0005 130.095 77.1544 125.409 76.6196 115.372C76.2232 107.93 81.9158 99.626 99.0812 98.6368C101.047 98.5234 102.976 98.468 104.871 98.468C111.106 98.468 116.939 99.0737 122.242 100.233C120.264 124.935 108.662 128.946 98.4405 129.507Z"></path></svg>',
                color: '#000000',
                maxLength: 500,
                imageRatio: '1:1' // Square
            }
        };

        // Demo placeholder images
        const DEMO_IMAGES = {
            main: 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=800&h=600&fit=crop',
            teaser: 'https://images.unsplash.com/photo-1557804506-669a67965ba0?w=800&h=600&fit=crop',
            placeholder: 'https://via.placeholder.com/800x600/e5e7eb/9ca3af?text=No+Image'
        };

        // Global state
        let state = {
            apiKey: '{{{apiKey}}}',
            neonAppUrl: '{{{neonAppUrl}}}',
            neonContext: null,
            drafts: {},
            writebacks: {},
            pollingIntervals: {},
            demoMode: false,
            isEmbedded: false,  // Track if panel is embedded in iframe
            availableImages: {
                main: null,      // mainPicture.ref
                teaser: null     // First hyperlink image (could be teaserImage)
            }
        };

        // API Helper
        function apiCall(endpoint, method = 'GET', body = null) {
            const path = `/panels/social-media/api/${endpoint}`;
            const options = {
                method,
                headers: {
                    'Content-Type': 'application/json',
                    'apikey': state.apiKey
                }
            };
            if (body) options.body = JSON.stringify(body);
            return PanelAPI.apiCallJson(path, options);
        }

        // Detect if panel is embedded in iframe
        function detectEmbedded() {
            try {
                // Check if we're in an iframe
                state.isEmbedded = window.self !== window.top;
            } catch (e) {
                // If we can't access window.top due to CORS, we're definitely embedded
                state.isEmbedded = true;
            }

            console.log('[Social Media Panel] Embedded mode:', state.isEmbedded);

            // Toggle header visibility based on embedded state
            if (state.isEmbedded) {
                document.getElementById('full-header').classList.add('hidden');
                document.getElementById('compact-header').classList.remove('hidden');
                // Reduce padding for embedded mode
                document.getElementById('app').classList.remove('p-6');
                document.getElementById('app').classList.add('p-3');
            } else {
                document.getElementById('full-header').classList.remove('hidden');
                document.getElementById('compact-header').classList.add('hidden');
            }
        }

        // Initialize panel
        function init() {
            // Detect if embedded
            detectEmbedded();

            // Check for demo mode in query parameter
            const urlParams = new URLSearchParams(window.location.search);
            const demoParam = urlParams.get('demo');

            if (demoParam === 'true') {
                state.demoMode = true;
                console.log('[Social Media Panel] Demo mode enabled');
                loadDemoData();
                renderSocialCards();
                document.getElementById('loading').classList.add('hidden');
                document.getElementById('social-container').classList.remove('hidden');
            } else {
                setupPostMessageApi();
            }

            setupGenerateAllButton();
            setupSaveButton();
        }

        // Load demo data for demonstration
        function loadDemoData() {
            // Load demo images
            state.availableImages = {
                main: DEMO_IMAGES.main,
                teaser: DEMO_IMAGES.teaser
            };

            // Demo drafts - ALL ENABLED BY DEFAULT
            state.drafts = {
                bluesky: {
                    enabled: true,
                    text: "🚀 New article: AI is transforming journalism! Exploring the intersection of technology and storytelling.\n\nhttps://example.com/article-123",
                    hashtags: ['AI', 'journalism', 'tech'],
                    selectedImage: 'main'
                },
                twitter: {
                    enabled: true,
                    text: "Breaking: AI transforms journalism 🤖📰 New insights on the future of media\n\nhttps://example.com/article-123",
                    hashtags: ['AI', 'journalism', 'tech'],
                    selectedImage: 'main'
                },
                facebook: {
                    enabled: true,
                    text: "🚀 Exciting news! Check out our latest article on innovation and technology. We explore how AI is transforming the media industry. Read more at https://example.com/article-123",
                    hashtags: ['innovation', 'technology', 'AI', 'media'],
                    selectedImage: 'main'
                },
                instagram: {
                    enabled: true,
                    text: "The media revolution is happening right now! 📱✨\n\nSwipe to learn how AI is changing journalism forever. Link in bio!\n\n📸 Behind the scenes of modern newsrooms",
                    hashtags: ['journalism', 'AI', 'innovation', 'media', 'tech'],
                    selectedImage: 'main'
                },
                threads: {
                    enabled: true,
                    text: "Just published a deep dive into AI and journalism. The future is fascinating! 🌟\n\nWhat are your thoughts on AI-generated content?\n\nhttps://example.com/article-123",
                    hashtags: ['journalism', 'AI', 'future'],
                    selectedImage: 'teaser'
                }
            };

            // Demo writebacks (simulating published posts)
            state.writebacks = {
                facebook: {
                    postId: '123456789_987654321',
                    url: 'https://facebook.com/posts/987654321',
                    publishedAt: new Date(Date.now() - 2 * 60 * 60 * 1000).toISOString(), // 2 hours ago
                    publishedBy: 'demo.user@example.com'
                },
                twitter: {
                    postId: '1234567890123456789',
                    url: 'https://twitter.com/user/status/1234567890123456789',
                    publishedAt: new Date(Date.now() - 45 * 60 * 1000).toISOString(), // 45 minutes ago
                    publishedBy: 'demo.user@example.com'
                }
            };

            // Show demo badge
            document.getElementById('demo-badge').classList.remove('hidden');

            console.log('[Social Media Panel] Demo data loaded');
        }

        // PostMessage API
        function setupPostMessageApi() {
            window.addEventListener('message', (event) => {
                if (event.origin !== state.neonAppUrl && event.origin !== window.parent.origin) {
                    return;
                }

                if (event.data && event.data.key === 'getInfo') {
                    state.neonContext = event.data.info;
                    console.log('[Social Media Panel] Received Neon context');
                    loadDraftsFromContext();
                    renderSocialCards();
                    document.getElementById('loading').classList.add('hidden');
                    document.getElementById('social-container').classList.remove('hidden');
                }
            });

            window.parent.postMessage({
                type: 'panel-ready',
                info: { op: 'getInfo' }
            }, window.parent.origin);
        }

        // Extract images from Neon context
        function extractImagesFromContext() {
            const node = state.neonContext?.originalNode;
            if (!node || !node.linkedNodeRefs) return;

            // Extract mainPicture
            const mainPicture = node.linkedNodeRefs.system?.mainPicture?.[0];
            if (mainPicture) {
                state.availableImages.main = mainPicture.ref;
                console.log('[Social Media Panel] Found mainPicture:', mainPicture.ref);
            }

            // Extract first hyperlink image as teaser (could include teaserImage)
            const hyperlinkImages = node.linkedNodeRefs.hyperlink?.image;
            if (hyperlinkImages && hyperlinkImages.length > 0) {
                state.availableImages.teaser = hyperlinkImages[0].ref;
                console.log('[Social Media Panel] Found teaser image:', hyperlinkImages[0].ref);
            }

            console.log('[Social Media Panel] Available images:', state.availableImages);
        }

        // Load drafts and writebacks from Neon context
        function loadDraftsFromContext() {
            const node = state.neonContext?.originalNode;
            if (!node) return;

            // Extract images first
            extractImagesFromContext();

            // Load drafts from metadata (or set default enabled state)
            if (node.metadata?.socialMediaDraft) {
                state.drafts = node.metadata.socialMediaDraft;
            } else {
                // Initialize all platforms as enabled by default
                state.drafts = {};
                for (const platform of Object.keys(PLATFORMS)) {
                    state.drafts[platform] = {
                        enabled: true,
                        text: '',
                        hashtags: [],
                        selectedImage: state.availableImages.main ? 'main' : 'none'
                    };
                }
                console.log('[Social Media Panel] Initialized default drafts (all enabled)');
            }

            // Load writebacks from publishInfos
            const publishInfos = node.publishInfos || {};
            for (const [siteId, info] of Object.entries(publishInfos)) {
                if (info.webhookData?.socialMediaHook) {
                    state.writebacks = info.webhookData.socialMediaHook;
                    break;
                }
            }

            console.log('[Social Media Panel] Loaded drafts:', state.drafts);
            console.log('[Social Media Panel] Loaded writebacks:', state.writebacks);
        }

        // Render social media cards
        function renderSocialCards() {
            const container = document.querySelector('.social-cards-container');
            container.innerHTML = '';

            for (const [platform, config] of Object.entries(PLATFORMS)) {
                const card = createSocialCard(platform, config);
                container.appendChild(card);
            }
        }

        // Create individual social card
        function createSocialCard(platform, config) {
            const draft = state.drafts[platform] || { enabled: true, text: '', hashtags: [], selectedImage: 'main' };
            const writeback = state.writebacks[platform];

            const card = document.createElement('div');
            card.className = `social-card platform-${platform} bg-white rounded-lg shadow-md p-6`;
            card.id = `card-${platform}`;

            if (writeback) {
                card.innerHTML = renderPublishedCard(platform, config, writeback);
                startMetricsPolling(platform, writeback.postId);
            } else {
                card.innerHTML = renderDraftCard(platform, config, draft);
                setupDraftCardEvents(platform);
            }

            return card;
        }

        // Get image URL for display (handle both Neon refs and direct URLs)
        function getImageUrl(imageType) {
            if (!imageType || imageType === 'none') return null;

            const ref = state.availableImages[imageType];
            if (!ref) return null;

            // If it's already a URL (demo mode), return it
            if (ref.startsWith('http')) return ref;

            // Otherwise it's a Neon ref - would need BO URL to construct full path
            // For now, return placeholder in non-demo mode
            return state.demoMode ? ref : DEMO_IMAGES.placeholder;
        }

        // Render draft mode card
        function renderDraftCard(platform, config, draft) {
            const selectedImage = draft.selectedImage || 'none';
            const selectedImageUrl = getImageUrl(selectedImage);

            // Build image selector options
            let imageOptions = '';

            if (state.availableImages.main) {
                const mainUrl = getImageUrl('main');
                imageOptions += `
                    <div class="image-option ${selectedImage === 'main' ? 'selected' : ''}" data-image="main">
                        <img src="${mainUrl}" alt="Main image" />
                        <div class="checkmark">✓</div>
                    </div>
                `;
            }

            if (state.availableImages.teaser) {
                const teaserUrl = getImageUrl('teaser');
                imageOptions += `
                    <div class="image-option ${selectedImage === 'teaser' ? 'selected' : ''}" data-image="teaser">
                        <img src="${teaserUrl}" alt="Teaser image" />
                        <div class="checkmark">✓</div>
                    </div>
                `;
            }

            // Always include "no image" option
            imageOptions += `
                <div class="image-option no-image ${selectedImage === 'none' ? 'selected' : ''}" data-image="none">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    <div class="checkmark">✓</div>
                </div>
            `;

            return `
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="platform-icon">${config.icon}</div>
                        <div>
                            <h3 class="text-lg font-semibold text-gray-800">${config.name}</h3>
                            <span class="text-xs text-gray-500">${config.imageRatio} • Max ${config.maxLength} chars</span>
                        </div>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="toggle-${platform}" ${draft.enabled ? 'checked' : ''}>
                        <span class="slider"></span>
                    </label>
                </div>

                <div id="content-${platform}" class="${draft.enabled ? '' : 'hidden'}">
                    <!-- Image Preview -->
                    ${selectedImageUrl ? `
                        <div class="mb-4">
                            <img src="${selectedImageUrl}" class="image-preview" alt="Selected image" id="preview-${platform}" />
                        </div>
                    ` : ''}

                    <!-- Image Selector -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Attached Image</label>
                        <div class="image-selector" id="image-selector-${platform}">
                            ${imageOptions}
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Post Content</label>
                        <textarea
                            id="text-${platform}"
                            class="w-full p-3 border border-gray-300 rounded-lg resize-none"
                            rows="5"
                            maxlength="${config.maxLength}"
                            placeholder="Write your ${config.name} post..."
                        >${draft.text || ''}</textarea>
                        <div class="flex justify-between items-center mt-1">
                            <span class="text-xs text-gray-500">
                                <span id="count-${platform}">${(draft.text || '').length}</span> / ${config.maxLength}
                            </span>
                            <button
                                id="ai-${platform}"
                                class="ai-button px-3 py-1 text-white text-sm font-medium rounded-lg flex items-center space-x-1"
                            >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                                </svg>
                                <span>Generate with AI</span>
                            </button>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Hashtags</label>
                        <input
                            id="hashtags-${platform}"
                            type="text"
                            class="w-full p-2 border border-gray-300 rounded-lg"
                            placeholder="technology, news, innovation"
                            value="${(draft.hashtags || []).join(', ')}"
                        >
                        <span class="text-xs text-gray-500 mt-1 block">Separate with commas</span>
                    </div>
                </div>

                <div id="disabled-${platform}" class="${draft.enabled ? 'hidden' : ''} text-center py-8 text-gray-400">
                    <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                    </svg>
                    <p>Enable to publish to ${config.name}</p>
                </div>
            `;
        }

        // Render published mode card
        function renderPublishedCard(platform, config, writeback) {
            return `
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center space-x-3">
                        <div class="platform-icon">${config.icon}</div>
                        <h3 class="text-lg font-semibold text-gray-800">${config.name}</h3>
                    </div>
                    <span class="px-3 py-1 bg-green-100 text-green-800 text-sm font-medium rounded-full">
                        ✓ Published
                    </span>
                </div>

                <div class="mb-4 pb-4 border-b border-gray-200">
                    <p class="text-sm text-gray-600 mb-1">
                        <strong>Post ID:</strong> <span class="text-xs font-mono">${writeback.postId.substring(0, 30)}...</span>
                    </p>
                    <p class="text-sm text-gray-600 mb-1">
                        <strong>Published:</strong> ${formatDate(writeback.publishedAt)}
                    </p>
                    <p class="text-sm text-gray-600">
                        <strong>By:</strong> ${writeback.publishedBy}
                    </p>
                </div>

                <div id="metrics-${platform}">
                    <div class="flex items-center justify-center py-4">
                        <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-600"></div>
                        <span class="ml-2 text-sm text-gray-600">Loading metrics...</span>
                    </div>
                </div>

                <div id="error-${platform}" class="hidden">
                    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4">
                        <p class="text-sm text-yellow-800 flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                            </svg>
                            Post not found or unavailable
                        </p>
                    </div>
                </div>

                <a
                    href="${writeback.url}"
                    target="_blank"
                    class="block w-full text-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg transition-colors"
                >
                    View on ${config.name} →
                </a>
            `;
        }

        // Setup draft card events
        function setupDraftCardEvents(platform) {
            // Use setTimeout to ensure DOM elements are rendered
            setTimeout(() => {
                const toggle = document.getElementById(`toggle-${platform}`);
                const content = document.getElementById(`content-${platform}`);
                const disabled = document.getElementById(`disabled-${platform}`);
                const textarea = document.getElementById(`text-${platform}`);
                const aiBtn = document.getElementById(`ai-${platform}`);
                const counter = document.getElementById(`count-${platform}`);
                const imageSelector = document.getElementById(`image-selector-${platform}`);

                // Check if elements exist (safety check)
                if (!toggle || !textarea || !aiBtn) {
                    console.warn(`[Social Media Panel] Elements not found for ${platform}, skipping event setup`);
                    return;
                }

                toggle.addEventListener('change', () => {
                    const enabled = toggle.checked;
                    content.classList.toggle('hidden', !enabled);
                    disabled.classList.toggle('hidden', enabled);

                    if (!state.drafts[platform]) {
                        state.drafts[platform] = {};
                    }
                    state.drafts[platform].enabled = enabled;
                });

                textarea.addEventListener('input', () => {
                    counter.textContent = textarea.value.length;
                    if (!state.drafts[platform]) {
                        state.drafts[platform] = { enabled: true };
                    }
                    state.drafts[platform].text = textarea.value;
                });

                aiBtn.addEventListener('click', () => generateWithAI(platform));

                // Image selector events
                if (imageSelector) {
                    const imageOptions = imageSelector.querySelectorAll('.image-option');
                    imageOptions.forEach(option => {
                        option.addEventListener('click', () => {
                            const selectedImage = option.getAttribute('data-image');

                            // Update UI
                            imageOptions.forEach(opt => opt.classList.remove('selected'));
                            option.classList.add('selected');

                            // Update state
                            if (!state.drafts[platform]) {
                                state.drafts[platform] = { enabled: true };
                            }
                            state.drafts[platform].selectedImage = selectedImage;

                            // Update preview
                            const preview = document.getElementById(`preview-${platform}`);
                            const imageUrl = getImageUrl(selectedImage);

                            if (imageUrl && preview) {
                                preview.src = imageUrl;
                                preview.parentElement.classList.remove('hidden');
                            } else if (preview) {
                                preview.parentElement.classList.add('hidden');
                            }

                            console.log(`[Social Media Panel] ${platform} image changed to:`, selectedImage);
                        });
                    });
                }
            }, 0);
        }

        // Generate content with AI
        async function generateWithAI(platform) {
            const button = document.getElementById(`ai-${platform}`);
            const textarea = document.getElementById(`text-${platform}`);
            const hashtagsInput = document.getElementById(`hashtags-${platform}`);

            button.disabled = true;
            button.innerHTML = '<div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div><span>Generating...</span>';

            try {
                let result;

                // In demo mode, use fake generated content
                if (state.demoMode) {
                    await new Promise(resolve => setTimeout(resolve, 1500)); // Simulate API delay
                    result = generateDemoContent(platform);
                } else {
                    result = await apiCall('generate-post', 'POST', {
                        platform: platform,
                        neonContext: state.neonContext
                    });
                }

                textarea.value = result.text;
                hashtagsInput.value = result.hashtags.join(', ');
                document.getElementById(`count-${platform}`).textContent = result.text.length;

                if (!state.drafts[platform]) {
                    state.drafts[platform] = { enabled: true };
                }
                state.drafts[platform].text = result.text;
                state.drafts[platform].hashtags = result.hashtags;

                button.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span>Generated!</span>';
                setTimeout(() => {
                    button.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg><span>Generate with AI</span>';
                    button.disabled = false;
                }, 2000);
            } catch (error) {
                console.error('AI generation failed:', error);
                alert('Failed to generate content. Please try again.');
                button.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg><span>Generate with AI</span>';
                button.disabled = false;
            }
        }

        // Generate demo content (AI simulation)
        function generateDemoContent(platform) {
            const demoContent = {
                facebook: {
                    text: "🚀 Discover the future of digital journalism! Our latest article explores how AI and machine learning are revolutionizing content creation and distribution. From automated fact-checking to personalized news feeds, the media landscape is evolving rapidly.\n\nRead the full story: https://example.com/article-ai-journalism",
                    hashtags: ['journalism', 'AI', 'innovation', 'media', 'technology']
                },
                twitter: {
                    text: "The future of journalism is here 🤖📰\n\nAI is transforming how we create and consume news. New article explores the latest trends.\n\nhttps://example.com/article-ai",
                    hashtags: ['AI', 'journalism', 'tech', 'news']
                },
                instagram: {
                    text: "The media revolution is happening right now! 📱✨\n\nSwipe to learn how AI is changing journalism forever. From automated reporting to personalized content, the future is fascinating.\n\nLink in bio for full article!\n\n📸 Behind the scenes of modern newsrooms where humans and AI collaborate to bring you the best stories.",
                    hashtags: ['journalism', 'AI', 'innovation', 'media', 'tech', 'digital', 'future', 'news', 'content', 'storytelling']
                },
                threads: {
                    text: "Just read a fascinating piece on AI in journalism 📰\n\nThe way newsrooms are adapting to new tech is incredible. We're not replacing journalists - we're empowering them with better tools.\n\nWhat's your take? Are you excited or concerned about AI in media?\n\nhttps://example.com/article-ai",
                    hashtags: ['journalism', 'AI', 'media', 'discussion']
                },
                bluesky: {
                    text: "New post: How AI is transforming journalism 🚀\n\nExploring the intersection of technology and storytelling. Spoiler: It's more about empowering journalists than replacing them.\n\nhttps://example.com/article-ai-journalism",
                    hashtags: ['journalism', 'AI', 'tech']
                }
            };

            return demoContent[platform] || {
                text: `Check out our latest article! ${PLATFORMS[platform].name} post about innovation. https://example.com/article`,
                hashtags: ['news', 'update']
            };
        }

        // Generate all posts with AI
        async function handleGenerateAll(button, originalHTML) {
            button.disabled = true;
            const isCompact = button.id.includes('compact');
            const spinnerSize = isCompact ? 'h-4 w-4' : 'h-5 w-5';

            button.innerHTML = `<div class="animate-spin rounded-full ${spinnerSize} border-b-2 border-white"></div><span>Generating...</span>`;

            const platforms = Object.keys(PLATFORMS).filter(p => state.drafts[p]?.enabled);
            let completed = 0;

            for (const platform of platforms) {
                try {
                    await generateWithAI(platform);
                    completed++;
                    button.innerHTML = `<span>${completed}/${platforms.length}...</span>`;
                } catch (error) {
                    console.error(`Failed to generate for ${platform}:`, error);
                }
            }

            const iconSize = isCompact ? 'w-4 h-4' : 'w-5 h-5';
            button.innerHTML = `<svg class="${iconSize}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span>${isCompact ? 'Done!' : 'All Generated!'}</span>`;

            setTimeout(() => {
                button.innerHTML = originalHTML;
                button.disabled = false;
            }, 2000);
        }

        async function setupGenerateAllButton() {
            const generateBtn = document.getElementById('generate-all-btn');
            const generateBtnCompact = document.getElementById('generate-all-btn-compact');

            if (generateBtn) {
                const originalHTML = generateBtn.innerHTML;
                generateBtn.addEventListener('click', () => handleGenerateAll(generateBtn, originalHTML));
            }

            if (generateBtnCompact) {
                const originalHTML = generateBtnCompact.innerHTML;
                generateBtnCompact.addEventListener('click', () => handleGenerateAll(generateBtnCompact, originalHTML));
            }
        }

        // Save all drafts
        function handleSaveAll(button, originalText) {
            // Collect all draft data
            for (const platform of Object.keys(PLATFORMS)) {
                const textarea = document.getElementById(`text-${platform}`);
                const hashtagsInput = document.getElementById(`hashtags-${platform}`);

                if (textarea && state.drafts[platform]?.enabled) {
                    state.drafts[platform].text = textarea.value;
                    const hashtagsValue = hashtagsInput.value.trim();
                    state.drafts[platform].hashtags = hashtagsValue ? hashtagsValue.split(',').map(h => h.trim()) : [];
                }
            }

            // Send to parent via PostMessage
            window.parent.postMessage({
                type: 'metadata-update',
                info: {
                    socialMediaDraft: state.drafts
                }
            }, window.parent.origin);

            button.textContent = '✓ Saved!';
            button.classList.add('bg-green-600');
            setTimeout(() => {
                button.textContent = originalText;
                button.classList.remove('bg-green-600');
            }, 2000);
        }

        function setupSaveButton() {
            const saveBtn = document.getElementById('save-all-btn');
            const saveBtnCompact = document.getElementById('save-all-btn-compact');

            if (saveBtn) {
                saveBtn.addEventListener('click', () => handleSaveAll(saveBtn, 'Save Posts'));
            }

            if (saveBtnCompact) {
                saveBtnCompact.addEventListener('click', () => handleSaveAll(saveBtnCompact, 'Save Posts'));
            }
        }

        // Start metrics polling for published posts
        function startMetricsPolling(platform, postId) {
            loadMetrics(platform, postId);

            const interval = setInterval(() => {
                if (!document.hidden) {
                    loadMetrics(platform, postId);
                }
            }, 30000); // 30 seconds

            state.pollingIntervals[platform] = interval;

            document.addEventListener('visibilitychange', () => {
                if (document.hidden) {
                    clearInterval(state.pollingIntervals[platform]);
                } else {
                    state.pollingIntervals[platform] = setInterval(() => {
                        loadMetrics(platform, postId);
                    }, 30000);
                }
            });
        }

        // Load metrics from API
        async function loadMetrics(platform, postId) {
            // In demo mode, use fake data
            if (state.demoMode) {
                const demoMetrics = generateDemoMetrics(platform);
                displayMetrics(platform, demoMetrics);
                return;
            }

            try {
                const result = await apiCall(`bluesky/metrics/${encodeURIComponent(postId)}`);

                if (result.success) {
                    displayMetrics(platform, result.metrics);
                } else {
                    showMetricsError(platform);
                }
            } catch (error) {
                console.error('Failed to load metrics:', error);
                showMetricsError(platform);
            }
        }

        // Generate demo metrics that increase over time
        function generateDemoMetrics(platform) {
            const baseMetrics = {
                facebook: { likes: 156, reposts: 23, replies: 18, quotes: 5 },
                twitter: { likes: 89, reposts: 34, replies: 12, quotes: 7 },
                bluesky: { likes: 45, reposts: 12, replies: 8, quotes: 3 }
            };

            const base = baseMetrics[platform] || { likes: 10, reposts: 2, replies: 1, quotes: 0 };

            // Add some random variation to simulate growth
            const randomVariation = () => Math.floor(Math.random() * 5);

            return {
                likes: base.likes + randomVariation(),
                reposts: base.reposts + randomVariation(),
                replies: base.replies + randomVariation(),
                quotes: base.quotes + randomVariation()
            };
        }

        // Display metrics in UI
        function displayMetrics(platform, metrics) {
            const container = document.getElementById(`metrics-${platform}`);
            const errorDiv = document.getElementById(`error-${platform}`);

            errorDiv.classList.add('hidden');
            container.innerHTML = `
                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div class="metric-badge">
                        <span>❤️</span>
                        <span class="font-semibold">${metrics.likes}</span>
                    </div>
                    <div class="metric-badge">
                        <span>🔁</span>
                        <span class="font-semibold">${metrics.reposts}</span>
                    </div>
                    <div class="metric-badge">
                        <span>💬</span>
                        <span class="font-semibold">${metrics.replies}</span>
                    </div>
                    <div class="metric-badge">
                        <span>📝</span>
                        <span class="font-semibold">${metrics.quotes || 0}</span>
                    </div>
                </div>
            `;
        }

        // Show metrics error
        function showMetricsError(platform) {
            const container = document.getElementById(`metrics-${platform}`);
            const errorDiv = document.getElementById(`error-${platform}`);

            container.classList.add('hidden');
            errorDiv.classList.remove('hidden');
        }

        // Format date helper
        function formatDate(dateString) {
            const date = new Date(dateString);
            const now = new Date();
            const diffMs = now - date;
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMs / 3600000);
            const diffDays = Math.floor(diffMs / 86400000);

            if (diffMins < 60) return `${diffMins}m ago`;
            if (diffHours < 24) return `${diffHours}h ago`;
            if (diffDays < 7) return `${diffDays}d ago`;

            return date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', init);

        // Cleanup on unload
        window.addEventListener('beforeunload', () => {
            for (const interval of Object.values(state.pollingIntervals)) {
                clearInterval(interval);
            }
        });
    </script>
</body>
</html>
