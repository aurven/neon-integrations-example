<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Analytics 4 - Page Analytics</title>
    <!-- Panel Bootstrap (inline with dynamic resource loading to avoid path issues when embedded) -->
    <script>(function(w){'use strict';function e(){try{return w.self!==w.top}catch(e){return true}}const m=e(),p=m?'/neon/api/demo-integration':'';w.__PANEL_EMBED_PREFIX__=p;w.__PANEL_IS_EMBEDDED__=m;const l=document.createElement('link');l.rel='stylesheet';l.href=p+'/css/tailwind-panels.css';document.head.appendChild(l);const s=document.createElement('script');s.src=p+'/js/panel-api-helper.js';document.head.appendChild(s)})(window);</script>
    <script src="/js/chart.js"></script>
    <script src="/neon/api/demo-integration/js/chart.js"></script>
    <script src="/js/ga4-data-generator.js"></script>
    <script src="/neon/api/demo-integration/js/ga4-data-generator.js"></script>
    <script src="/js/ga4-charts.js"></script>
    <script src="/neon/api/demo-integration/js/ga4-charts.js"></script>
    <style>
        /* Google Sans font fallback */
        body {
            font-family: 'Google Sans', 'Product Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        /* GA4 color variables */
        :root {
            --ga-blue: #1a73e8;
            --ga-red: #ea4335;
            --ga-yellow: #fbbc04;
            --ga-green: #34a853;
            --ga-text-primary: #202124;
            --ga-text-secondary: #5f6368;
            --ga-border: #dadce0;
            --ga-background: #f8f9fa;
        }

        /* Chart containers */
        .chart-container {
            position: relative;
            width: 100%;
            height: 300px;
        }

        /* GA Logo animation */
        @keyframes pulse-slow {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.8;
            }
        }

        .ga-logo-animated {
            animation: pulse-slow 3s ease-in-out infinite;
        }
    </style>
</head>

<body class="bg-gray-50">
    <div class="min-h-screen p-6">
        <div class="max-w-7xl mx-auto">
            <!-- Header with GA Logo and Breadcrumb -->
            <div class="bg-white rounded-lg shadow-sm p-4 mb-4 border border-gray-200">
                <div class="flex items-center space-x-3">
                    <!-- Google Analytics Logo (SVG) -->
                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
                            width="48px" height="48px" viewBox="0 0 192 192" enable-background="new 0 0 192 192" xml:space="preserve">
                        <rect x="0" y="0" fill="none" width="192" height="192"/>
                        <g>
                            <g>
                                <path fill="#F9AB00" d="M130,29v132c0,14.77,10.19,23,21,23c10,0,21-7,21-23V30c0-13.54-10-22-21-22S130,17.33,130,29z"/>
                            </g>
                            <g>
                                <path fill="#E37400" d="M75,96v65c0,14.77,10.19,23,21,23c10,0,21-7,21-23V97c0-13.54-10-22-21-22S75,84.33,75,96z"/>
                            </g>
                            <g>
                                <circle fill="#E37400" cx="41" cy="163" r="21"/>
                            </g>
                        </g>
                    </svg>
                    <div>
                        <h1 class="text-lg font-medium text-gray-900">Google Analytics</h1>
                        <div class="text-xs text-gray-500">
                            <span>Home</span>
                            <span class="mx-1">›</span>
                            <span>Reports</span>
                            <span class="mx-1">›</span>
                            <span>Pages and screens</span>
                            <span class="mx-1">›</span>
                            <div class="font-medium text-gray-700" id="breadcrumb-title">Page Analytics</div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center space-x-2 mt-4">
                    <span class="text-xs text-gray-500">Last 7 days</span>
                    <div class="px-3 py-1 bg-gray-100 rounded text-xs font-medium text-gray-700">
                        📅 <span id="date-range">Oct 22 - Oct 28, 2025</span>
                    </div>
                </div>
            </div>

            <!-- Page Title and Link -->
            <div class="bg-white rounded-lg shadow-sm p-4 mb-4 border border-gray-200" hidden>
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <h2 class="text-2xl font-medium text-gray-900 mb-2" id="page-title">Article Analytics</h2>
                        <div class="flex items-center space-x-2">
                            <span class="text-sm text-gray-600" id="page-url">https://example.com/article/...</span>
                            <a href="#" id="ga-link" target="_blank" class="inline-flex items-center text-xs text-blue-600 hover:text-blue-700">
                                🔗 View in GA4
                            </a>
                        </div>
                    </div>
                    <div class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-medium">
                        ⚫ LIVE
                    </div>
                </div>
            </div>

            <!-- Metrics Grid (2 cols on mobile, 3 cols on tablets, 4 cols on larger screens) -->
            <div class="grid grid-cols-2 xs:grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
                <!-- Users Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-medium text-gray-500 uppercase block mb-1">👥 Users</span>
                        <span class="trend-indicator text-xs font-semibold" id="users-trend"></span>
                    </div>
                    <div class="text-2xl font-normal text-gray-900" id="metric-users">0</div>
                </div>

                <!-- Views Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-medium text-gray-500 uppercase block mb-1">📄 Views</span>
                        <span class="trend-indicator text-xs font-semibold" id="views-trend"></span>
                    </div>
                    <div class="text-2xl font-normal text-gray-900" id="metric-views">0</div>
                </div>

                <!-- Avg Engagement Time Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-medium text-gray-500 uppercase block mb-1">⏱️ Avg Time</span>
                        <span class="trend-indicator text-xs font-semibold" id="time-trend"></span>
                    </div>
                    <div class="text-2xl font-normal text-gray-900" id="metric-time">0:00</div>
                </div>

                <!-- Bounce Rate Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-medium text-gray-500 uppercase block mb-1">📊 Bounce</span>
                        <span class="trend-indicator text-xs font-semibold" id="bounce-trend"></span>
                    </div>
                    <div class="text-2xl font-normal text-gray-900" id="metric-bounce">0%</div>
                </div>

                <!-- Engagement Rate Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-medium text-gray-500 uppercase block mb-1">🔄 Engagement</span>
                        <span class="trend-indicator text-xs font-semibold" id="engagement-trend"></span>
                    </div>
                    <div class="text-2xl font-normal text-gray-900" id="metric-engagement">0%</div>
                </div>

                <!-- Conversions Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-medium text-gray-500 uppercase block mb-1">⭐ Conversions</span>
                        <span class="trend-indicator text-xs font-semibold" id="conversions-trend"></span>
                    </div>
                    <div class="text-2xl font-normal text-gray-900" id="metric-conversions">0</div>
                </div>
            </div>

            <!-- Traffic Over Time Chart -->
            <div class="bg-white rounded-lg shadow-sm p-6 mb-4 border border-gray-200">
                <h3 class="text-base font-medium text-gray-900 mb-4">Users Over Time</h3>
                <div class="chart-container">
                    <canvas id="traffic-time-chart"></canvas>
                </div>
            </div>

            <!-- Traffic Sources Chart -->
            <div class="bg-white rounded-lg shadow-sm p-6 mb-4 border border-gray-200">
                <h3 class="text-base font-medium text-gray-900 mb-4">Traffic Sources</h3>
                <div class="max-w-2xl mx-auto">
                    <canvas id="traffic-sources-chart"></canvas>
                </div>
            </div>

            <!-- Device Category Chart -->
            <div class="bg-white rounded-lg shadow-sm p-6 mb-4 border border-gray-200">
                <h3 class="text-base font-medium text-gray-900 mb-4">Device Category</h3>
                <div class="max-w-md mx-auto">
                    <canvas id="device-chart"></canvas>
                </div>
            </div>

            <!-- Events and User Flow -->
            <div class="grid grid-cols-1 xs:grid-cols-1 gap-4">
                <!-- Top Events -->
                <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
                    <h3 class="text-base font-medium text-gray-900 mb-4">Top Events</h3>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm text-gray-700">🖱️ page_view</span>
                            <span class="text-sm font-medium text-gray-900" id="event-pageview">0</span>
                        </div>
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm text-gray-700">📜 scroll</span>
                            <span class="text-sm font-medium text-gray-900" id="event-scroll">0</span>
                        </div>
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm text-gray-700">🔗 click</span>
                            <span class="text-sm font-medium text-gray-900" id="event-click">0</span>
                        </div>
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm text-gray-700">📤 share</span>
                            <span class="text-sm font-medium text-gray-900" id="event-share">0</span>
                        </div>
                        <div class="flex items-center justify-between py-2">
                            <span class="text-sm text-gray-700">💬 form_submit</span>
                            <span class="text-sm font-medium text-gray-900" id="event-formsubmit">0</span>
                        </div>
                    </div>
                </div>

                <!-- User Flow -->
                <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
                    <h3 class="text-base font-medium text-gray-900 mb-4">User Flow</h3>
                    <div class="space-y-4 pt-2">
                        <div>
                            <div class="text-sm font-medium text-gray-700 mb-1">Entry Page</div>
                            <div class="flex items-center">
                                <div class="w-full bg-blue-100 rounded h-8 flex items-center px-3">
                                    <span class="text-sm text-blue-800 font-medium">100%</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center text-gray-400">
                            <div class="w-8 text-center">↓</div>
                        </div>
                        <div>
                            <div class="text-sm font-medium text-gray-700 mb-1">Exit Behavior</div>
                            <div class="space-y-2">
                                <div class="flex items-center">
                                    <div class="w-1/2 bg-red-100 rounded h-6 flex items-center px-3">
                                        <span class="text-xs text-red-800 font-medium">50% → Exit</span>
                                    </div>
                                </div>
                                <div class="flex items-center">
                                    <div class="w-1/3 bg-green-100 rounded h-6 flex items-center px-3">
                                        <span class="text-xs text-green-800 font-medium">35% → Next Article</span>
                                    </div>
                                </div>
                                <div class="flex items-center">
                                    <div class="w-1/6 bg-blue-100 rounded h-6 flex items-center px-3">
                                        <span class="text-xs text-blue-800 font-medium">15% → Home</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="mt-6 text-center text-xs text-gray-500" hidden>
                <p>Mockup data generated from article UUID • Not real Google Analytics data</p>
            </div>
        </div>
    </div>

    <script>
        // Get objectId from URL parameters
        const urlParams = new URLSearchParams(window.location.search);
        const objectId = urlParams.get('objectId') || 'demo-article-uuid-12345';

        // Generate GA4 metrics data
        const metricsData = GA4DataGenerator.generateGA4Metrics(objectId);

        // Update page title and URL
        document.getElementById('page-title').textContent = `Article Analytics (${objectId.substring(0, 8)}...)`;
        document.getElementById('page-url').textContent = `https://example.com/article/${objectId.substring(0, 12)}`;
        //document.getElementById('breadcrumb-title').textContent = objectId.substring(0, 12) + '...';
        document.getElementById('breadcrumb-title').textContent = objectId;

        // Generate fake GA4 link
        const gaLink = `https://analytics.google.com/analytics/web/#/p123456789/reports/pages-and-screens?params=_u..date00%3D20251022%26date01%3D20251028%26page%3D%252Farticle%252F${objectId.substring(0, 12)}`;
        document.getElementById('ga-link').href = gaLink;

        // Update primary metrics
        document.getElementById('metric-users').textContent = metricsData.users.toLocaleString();
        document.getElementById('metric-views').textContent = metricsData.views.toLocaleString();
        document.getElementById('metric-time').textContent = metricsData.avgEngagementTimeFormatted;
        document.getElementById('metric-bounce').textContent = metricsData.bounceRate.toFixed(1) + '%';
        document.getElementById('metric-engagement').textContent = metricsData.engagementRate.toFixed(1) + '%';
        document.getElementById('metric-conversions').textContent = metricsData.conversions.toLocaleString();

        // Update trends
        function updateTrend(elementId, trend, inverse = false) {
            const indicator = GA4DataGenerator.getTrendIndicator(trend, inverse);
            const element = document.getElementById(elementId);
            element.textContent = indicator.icon + ' ' + indicator.value;
            element.className = 'text-sm font-semibold ' + indicator.color;
        }

        updateTrend('users-trend', metricsData.trends.users);
        updateTrend('views-trend', metricsData.trends.views);
        updateTrend('time-trend', metricsData.trends.avgEngagementTime);
        updateTrend('bounce-trend', metricsData.trends.bounceRate, true);  // Inverse: lower is better
        updateTrend('engagement-trend', metricsData.trends.engagementRate);
        updateTrend('conversions-trend', metricsData.trends.conversions);

        // Update events
        document.getElementById('event-pageview').textContent = metricsData.events.page_view.toLocaleString();
        document.getElementById('event-scroll').textContent = metricsData.events.scroll.toLocaleString();
        document.getElementById('event-click').textContent = metricsData.events.click.toLocaleString();
        document.getElementById('event-share').textContent = metricsData.events.share.toLocaleString();
        document.getElementById('event-formsubmit').textContent = metricsData.events.form_submit.toLocaleString();

        // Initialize charts when Chart.js is loaded
        window.addEventListener('load', function() {
            // Traffic over time chart
            GA4Charts.initTrafficTimeChart(
                'traffic-time-chart',
                metricsData.timeSeriesLabels,
                metricsData.timeSeriesData
            );

            // Traffic sources chart
            GA4Charts.initTrafficSourcesChart(
                'traffic-sources-chart',
                metricsData.trafficSources
            );

            // Device category chart
            GA4Charts.initDeviceChart(
                'device-chart',
                metricsData.devices
            );

            console.log('GA4 Analytics Panel loaded with data:', metricsData);
        });
    </script>
</body>

</html>
