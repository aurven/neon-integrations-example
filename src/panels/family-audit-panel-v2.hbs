<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Family Audit</title>
    <script src="/js/panel-api-helper.js"></script>
    <script src="/neon/api/demo-integration/js/panel-api-helper.js"></script>
    <link rel="stylesheet" href="/css/tailwind-panels.css">
    <link rel="stylesheet" href="/neon/api/demo-integration/css/tailwind-panels.css">
    <link rel="stylesheet" href="/fonts/fa6/css/fontawesome.css">
    <link rel="stylesheet" href="/neon/api/demo-integration/fonts/fa6/css/fontawesome.css">
    <link rel="stylesheet" href="/fonts/fa6/css/solid.css">
    <link rel="stylesheet" href="/neon/api/demo-integration/fonts/fa6/css/solid.css">
    <link rel="stylesheet" href="/css/family-audit-panel-v2.css">
    <link rel="stylesheet" href="/neon/api/demo-integration/css/family-audit-panel-v2.css">
</head>
<body>
<div id="famaud-root">
    <header class="famaud-header">
        <div class="famaud-filter-row" id="famaud-filter-row">
            <button class="famaud-filter-btn active" data-filter="lock" title="Lock / Unlock">
                <i class="fa-solid fa-lock"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="save" title="Save">
                <i class="fa-solid fa-floppy-disk"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="create" title="Create">
                <i class="fa-solid fa-file-circle-plus"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="publish" title="Publish">
                <i class="fa-solid fa-tower-broadcast"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="unpublish" title="Unpublish">
                <i class="fa-solid fa-circle-xmark"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="workflow" title="Workflow">
                <i class="fa-solid fa-code-branch"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="notification" title="Notification">
                <i class="fa-solid fa-satellite-dish"></i>
            </button>
            <button class="famaud-filter-btn active" data-filter="collaboration" title="Collaboration session">
                <i class="fa-solid fa-users"></i>
            </button>
        </div>
        <div class="famaud-view-pill">
            <button class="famaud-view-toggle active" data-view="standard">Standard</button>
            <button class="famaud-view-toggle" data-view="advanced">Advanced</button>
        </div>
    </header>
    <div id="famaud-content"></div>
</div>

<script>
const CONFIG = { neonAppUrl: '{{neonAppUrl}}', apiKey: '{{{apiKey}}}' };
</script>
<script src="/js/family-audit-panel.js"></script>
<script src="/neon/api/demo-integration/js/family-audit-panel.js"></script>
</body>
</html>
