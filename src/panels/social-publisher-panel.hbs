<!-- src/panels/social-publisher-panel.hbs -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Social Publisher</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&display=swap">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#f9f9fb;color:#3f3c4e;font-family:"Source Sans 3","Source Sans Pro",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;font-size:14px;line-height:1.4;height:100vh;display:flex;flex-direction:column;overflow:hidden;-webkit-font-smoothing:antialiased}

/* Header */
.panel-header{padding:9px 14px;border-bottom:1px solid #dddce5;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;background:#fff}
.panel-title{font-weight:600;font-size:14px;color:#3f3c4e}
.hdr-actions{display:flex;gap:6px}

/* Buttons */
.btn{padding:5px 12px;border:1px solid #dddce5;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;font-family:inherit;line-height:1.4;transition:background 120ms ease-out,border-color 120ms ease-out}
.btn-ghost{background:#fff;color:#3f3c4e}.btn-ghost:hover{background:#f6f3f6}
.btn-primary{background:#0a2ee6;color:#fff;border-color:#0a2ee6}.btn-primary:hover{background:#171db5;border-color:#171db5}
.btn-primary:disabled{background:#aaa8b8;border-color:#aaa8b8;cursor:not-allowed}

/* Tabs */
.tabs{display:flex;border-bottom:1px solid #dddce5;flex-shrink:0;overflow-x:auto;background:#fff}
.tab{display:flex;align-items:center;gap:5px;padding:9px 13px;cursor:pointer;border-bottom:2px solid transparent;color:#69667f;font-size:12px;font-weight:500;white-space:nowrap;user-select:none;transition:color 120ms ease-out,background 120ms ease-out}
.tab:hover{color:#3f3c4e;background:#f6f3f6}
.tab.active{color:#3f3c4e;border-bottom-color:var(--tab-color,#0a2ee6)}
.tab-icon{font-size:13px}

/* Chips */
.chip{display:inline-block;font-size:10px;font-weight:600;padding:1px 6px;border-radius:4px;vertical-align:middle;letter-spacing:0.02em}
.chip-pub{background:#e8f5e9;color:#367d38}
.chip-draft{background:#fff8cc;color:#806600}
.chip-warn{background:#fff0f0;color:#d22d2d}
.chip-off{background:#f1f0f4;color:#9d9aac}

/* Tab body */
.tab-body{flex:1;overflow-y:auto;padding:14px}

/* Platform header */
.plat-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.plat-name{font-size:14px;font-weight:600;display:flex;align-items:center;gap:6px}
.char-cnt{font-size:12px;color:#9d9aac}
.char-cnt.warn{color:#806600}.char-cnt.err{color:#d22d2d}

/* Textarea */
textarea{width:100%;background:#fff;border:1px solid #dddce5;border-radius:8px;color:#3f3c4e;font-size:13px;line-height:1.5;padding:9px 11px;resize:vertical;min-height:88px;font-family:inherit;transition:border-color 120ms ease-out}
textarea:focus{outline:none;border-color:#0a2ee6;box-shadow:0 0 0 2px rgba(10,46,230,0.12)}
textarea::placeholder{color:#9d9aac}

/* Image selector */
.img-row{display:flex;gap:8px;align-items:flex-end;margin:10px 0}
.img-row-label{font-size:11px;color:#69667f;margin-right:2px;align-self:center}
.img-col{display:flex;flex-direction:column;align-items:center;gap:3px}
.img-thumb{width:54px;height:54px;border:1.5px solid #dddce5;border-radius:8px;cursor:pointer;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#f9f9fb;transition:border-color 120ms ease-out}
.img-thumb:hover{border-color:#aaa8b8}
.img-thumb.sel{border-color:#0a2ee6;box-shadow:0 0 0 2px rgba(10,46,230,0.15)}
.img-thumb img{width:100%;height:100%;object-fit:cover}
.img-thumb .noimg{color:#aaa8b8;font-size:16px}
.img-lbl{font-size:10px;color:#9d9aac;font-weight:500}

/* Hashtag input */
.hashtag-inp{width:100%;background:#fff;border:1px solid #dddce5;border-radius:8px;color:#3f3c4e;font-size:13px;padding:7px 11px;margin:6px 0;font-family:inherit;transition:border-color 120ms ease-out}
.hashtag-inp:focus{outline:none;border-color:#0a2ee6;box-shadow:0 0 0 2px rgba(10,46,230,0.12)}
.hashtag-inp::placeholder{color:#9d9aac}

/* Warning banner */
.warn-banner{background:#fff0f0;border:1px solid rgba(210,45,45,0.2);border-radius:8px;padding:7px 11px;font-size:12px;color:#d22d2d;margin-bottom:8px}
.info-banner{background:#f0f4ff;border:1px solid rgba(10,46,230,0.15);border-radius:8px;padding:7px 11px;font-size:12px;color:#3f3c4e;margin-bottom:8px}

/* Draft actions */
.draft-actions{display:flex;gap:8px;align-items:center;margin-top:10px}
.btn-generate{background:#fff;border:1px solid #dddce5;color:#0a2ee6;font-weight:500}.btn-generate:hover{background:#f0f4ff;border-color:#0a2ee6}
.btn-generate:disabled{color:#9d9aac;border-color:#dddce5;background:#f9f9fb;cursor:not-allowed}
.btn-pub-action{margin-left:auto}

/* Published view */
.pub-card{background:#fff;border:1px solid #dddce5;border-radius:10px;padding:14px;box-shadow:0 1px 2px rgba(63,60,78,0.06)}
.pub-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.pub-platform{font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px}
.pub-meta{font-size:11px;color:#9d9aac;margin-top:3px}
.view-link{font-size:12px;font-weight:500;color:#0a2ee6;text-decoration:none;border:1px solid rgba(10,46,230,0.25);border-radius:8px;padding:4px 10px;white-space:nowrap;transition:background 120ms ease-out}
.view-link:hover{background:#f0f4ff}
.post-preview{border-left:3px solid var(--tab-color,#0a2ee6);background:#f9f9fb;border-radius:0 8px 8px 0;padding:9px 13px;font-size:13px;line-height:1.5;color:#3f3c4e;margin-bottom:14px;word-break:break-word}
.metrics-lbl{font-size:11px;color:#9d9aac;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;margin-bottom:8px}
.metrics-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.metric-card{background:#f9f9fb;border:1px solid #f1f0f4;border-radius:8px;padding:10px 8px;text-align:center}
.metric-val{font-size:18px;font-weight:700;color:#3f3c4e;margin-bottom:2px}
.metric-name{font-size:11px;color:#9d9aac}
.post-id{font-size:10px;color:#bfbfca;word-break:break-all;margin-top:10px}

/* Not configured */
.uncfg-notice{background:#fff;border:1px solid #dddce5;border-radius:10px;padding:20px;text-align:center;color:#9d9aac;font-size:13px}
</style>
</head>
<body>
<div class="panel-header">
  <span class="panel-title">Social publisher</span>
  <div class="hdr-actions">
    <button class="btn btn-ghost" onclick="handleGenerateAll()">Generate all</button>
    <button class="btn btn-ghost" onclick="handleSaveAll()">Save drafts</button>
  </div>
</div>
<div class="tabs" id="tabs"></div>
<div class="tab-body" id="tab-body"></div>

<script>
'use strict';

const PLATFORMS = {
  twitter:   { displayName:'Twitter / X', icon:'𝕏',  color:'#1d9bf0', maxLength:280,   requiresImage:false,
               metrics:[{k:'likes',l:'Likes'},{k:'reposts',l:'Reposts'},{k:'replies',l:'Replies'},{k:'impressions',l:'Impressions'}] },
  facebook:  { displayName:'Facebook',    icon:'f',   color:'#1877f2', maxLength:63206, requiresImage:false,
               metrics:[{k:'likes',l:'Likes'},{k:'shares',l:'Shares'},{k:'comments',l:'Comments'},{k:'reach',l:'Reach'}] },
  instagram: { displayName:'Instagram',   icon:'📷',  color:'#e1306c', maxLength:2200,  requiresImage:true,
               metrics:[{k:'likes',l:'Likes'},{k:'comments',l:'Comments'},{k:'saves',l:'Saves'},{k:'reach',l:'Reach'}] },
  threads:   { displayName:'Threads',     icon:'◎',   color:'#3f3c4e', maxLength:500,   requiresImage:false,
               metrics:[{k:'likes',l:'Likes'},{k:'reposts',l:'Reposts'},{k:'replies',l:'Replies'},{k:'quotes',l:'Quotes'}] },
  bluesky:   { displayName:'Bluesky',     icon:'☁',  color:'#0085ff', maxLength:300,   requiresImage:false,
               metrics:[{k:'likes',l:'Likes'},{k:'reposts',l:'Reposts'},{k:'replies',l:'Replies'},{k:'quotes',l:'Quotes'}] }
};

const state = {
  apiKey: '{{apiKey}}',
  neonAppUrl: '{{neonAppUrl}}',
  neonContext: null,
  active: 'twitter',
  status: {},
  drafts: Object.fromEntries(Object.keys(PLATFORMS).map(p => [p, { enabled:true, text:'', hashtags:[], selectedImage:'none' }])),
  writebacks: {},
  images: { main:null, teaser:null },
  metricsIntervals: {},
  generating: {},
  publishing: {}
};

// --- API ---
async function api(endpoint, method='GET', body=null) {
  const opts = { method, headers:{ 'Content-Type':'application/json', apikey:state.apiKey } };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(`/panels/social-publisher/api/${endpoint}`, opts);
  if (!res.ok) { const err = await res.json().catch(()=>({})); throw new Error(err.error || res.statusText); }
  return res.json();
}

// --- PostMessage ---
window.addEventListener('message', e => {
  if (!e.data) return;
  if (e.data.key === 'getInfo') { state.neonContext = e.data.info; loadFromContext(); render(); }
});

function loadFromContext() {
  if (!state.neonContext) return;
  const node = state.neonContext.originalNode || {};
  const saved = node.metadata?.socialMediaDraft || {};
  Object.keys(PLATFORMS).forEach(p => { if (saved[p]) Object.assign(state.drafts[p], saved[p]); });
  Object.values(state.neonContext.publishInfos || {}).forEach(site => {
    Object.assign(state.writebacks, site?.webhookData?.socialMediaHook || {});
  });
  const refs = node.linkedNodeRefs || {};
  state.images.main   = refs.system?.mainPicture?.[0]?.ref || null;
  state.images.teaser = refs.hyperlink?.image?.[0]?.ref || null;
}

function imgUrl(type) {
  const ref = state.images[type];
  return ref?.startsWith('http') ? ref : null;
}

// --- Status ---
async function loadStatuses() {
  await Promise.all(Object.keys(PLATFORMS).map(async p => {
    try { state.status[p] = await api(`${p}/status`); }
    catch (e) { state.status[p] = { configured:false, error:e.message }; }
  }));
  render();
}

// --- Render ---
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function fmtMetric(v) { if (v==null) return '—'; return v>=1000 ? (v/1000).toFixed(1)+'k' : String(v); }
function fmtDate(iso) { return iso ? new Date(iso).toLocaleString(undefined,{dateStyle:'medium',timeStyle:'short'}) : ''; }

function badge(p) {
  if (state.writebacks[p]) return `<span class="chip chip-pub">Published</span>`;
  if (state.status[p] && !state.status[p].configured) return `<span class="chip chip-off">Not configured</span>`;
  if (PLATFORMS[p].requiresImage && state.drafts[p].selectedImage==='none') return `<span class="chip chip-warn">Image required</span>`;
  if (state.drafts[p].text) return `<span class="chip chip-draft">Draft</span>`;
  return '';
}

function render() {
  const tabsEl = document.getElementById('tabs');
  tabsEl.innerHTML = Object.entries(PLATFORMS).map(([p,cfg]) =>
    `<div class="tab${state.active===p?' active':''}" style="--tab-color:${cfg.color}" onclick="switchTab('${p}')">
       <span class="tab-icon">${cfg.icon}</span><span>${cfg.displayName}</span>${badge(p)}</div>`
  ).join('');
  renderBody();
}

function renderBody() {
  const p = state.active, cfg = PLATFORMS[p];
  const el = document.getElementById('tab-body');
  el.style.setProperty('--tab-color', cfg.color);
  if (state.writebacks[p]) { renderPublished(el, p, cfg); startMetricsPoll(p); }
  else renderDraft(el, p, cfg);
}

function renderDraft(el, p, cfg) {
  const d = state.drafts[p];
  const configured = !state.status[p] || state.status[p].configured;
  const rem = cfg.maxLength - d.text.length;
  const charCls = rem < 20 ? 'err' : rem < 50 ? 'warn' : '';
  const needsImg = cfg.requiresImage && d.selectedImage==='none';
  const pubDisabled = !configured || needsImg || !!state.publishing[p];

  const imgOptions = ['main','teaser','none'].map(t => {
    const url = t!=='none' ? imgUrl(t) : null;
    return `<div class="img-col">
      <div class="img-thumb${d.selectedImage===t?' sel':''}" onclick="selImg('${p}','${t}')">
        ${url ? `<img src="${esc(url)}" alt="${t}">` : `<span class="noimg">${t==='none'?'✕':'?'}</span>`}
      </div><div class="img-lbl">${t}</div></div>`;
  }).join('');

  el.innerHTML = `
    <div class="plat-hdr">
      <span class="plat-name" style="color:${cfg.color}"><span>${cfg.icon}</span><span>${cfg.displayName}</span></span>
      <span class="char-cnt ${charCls}">${d.text.length} / ${cfg.maxLength}</span>
    </div>
    ${needsImg ? '<div class="warn-banner">Instagram requires an image to publish.</div>' : ''}
    ${!configured ? '<div class="info-banner">Connector not configured. Add environment variables and restart.</div>' : ''}
    <textarea oninput="onText('${p}',this.value)" placeholder="Write your ${esc(cfg.displayName)} post...">${esc(d.text)}</textarea>
    <div class="img-row"><span class="img-row-label">Image</span>${imgOptions}</div>
    <input class="hashtag-inp" placeholder="Hashtags (comma-separated, without #)"
      value="${esc(d.hashtags.join(', '))}" oninput="onTags('${p}',this.value)">
    <div class="draft-actions">
      <button class="btn btn-generate" onclick="handleGenerate('${p}')" ${state.generating[p]?'disabled':''}>
        ${state.generating[p]?'Generating…':'Generate'}</button>
      <button class="btn btn-primary btn-pub-action" onclick="handlePublish('${p}')" ${pubDisabled?'disabled':''}>
        ${state.publishing[p]?'Publishing…':'Publish'}</button>
    </div>`;
}

function renderPublished(el, p, cfg) {
  const wb = state.writebacks[p];
  const metricsCards = cfg.metrics.map(m =>
    `<div class="metric-card">
       <div class="metric-val" id="m-${p}-${m.k}">${fmtMetric(wb.metrics?.[m.k])}</div>
       <div class="metric-name">${m.l}</div></div>`
  ).join('');

  const viewHref = wb.url ? ` href="${esc(wb.url)}"` : '';
  el.innerHTML = `
    <div class="pub-card">
      <div class="pub-hdr">
        <div>
          <div class="pub-platform" style="color:${cfg.color}"><span>${cfg.icon}</span><span>${cfg.displayName}</span></div>
          <div class="pub-meta">Published ${fmtDate(wb.publishedAt)}${wb.publishedBy ? ' · ' + esc(wb.publishedBy) : ''}</div>
        </div>
        <a class="view-link"${viewHref} target="_blank" rel="noopener">View post</a>
      </div>
      <div class="post-preview">${esc(wb.text||'')}</div>
      <div class="metrics-lbl">Metrics <span style="font-weight:400;color:#bfbfca">· every 30s</span></div>
      <div class="metrics-grid">${metricsCards}</div>
      <div class="post-id">Post ID: ${esc(wb.postId)}</div>
    </div>`;
}

function updateMetricCards(p, metrics) {
  const cfg = PLATFORMS[p];
  cfg.metrics.forEach(m => {
    const el = document.getElementById(`m-${p}-${m.k}`);
    if (el) el.textContent = fmtMetric(metrics[m.k]);
  });
}

// --- Actions ---
function switchTab(p) { state.active = p; render(); }
function selImg(p, t) { state.drafts[p].selectedImage = t; renderBody(); }

function onText(p, v) {
  state.drafts[p].text = v;
  const cfg = PLATFORMS[p];
  const rem = cfg.maxLength - v.length;
  const cls = rem < 20 ? 'err' : rem < 50 ? 'warn' : '';
  const el = document.querySelector('.char-cnt');
  if (el) { el.className = `char-cnt ${cls}`; el.textContent = `${v.length} / ${cfg.maxLength}`; }
  const tabs = document.getElementById('tabs');
  if (tabs) {
    const tabEl = tabs.querySelector(`.tab:nth-child(${Object.keys(PLATFORMS).indexOf(p)+1})`);
    if (tabEl) { const b = tabEl.querySelector('.chip'); if (b) b.outerHTML = badge(p); else if (badge(p)) tabEl.insertAdjacentHTML('beforeend', badge(p)); }
  }
}

function onTags(p, v) {
  state.drafts[p].hashtags = v.split(',').map(t => t.trim().replace(/^#/,'')).filter(Boolean);
}

async function handleGenerate(p) {
  if (!state.neonContext) return;
  state.generating[p] = true; renderBody();
  try {
    const result = await api('generate-post', 'POST', { platform:p, neonContext:state.neonContext });
    if (result.text) {
      state.drafts[p].text = result.text;
      if (result.hashtags?.length) state.drafts[p].hashtags = result.hashtags;
    }
  } catch(e) { console.error('Generate failed:', e); }
  finally { state.generating[p] = false; renderBody(); }
}

async function handleGenerateAll() {
  for (const p of Object.keys(PLATFORMS)) {
    if (!state.writebacks[p]) await handleGenerate(p);
  }
}

async function handlePublish(p) {
  const d = state.drafts[p];
  state.publishing[p] = true; renderBody();
  try {
    const tags = d.hashtags.map(t => `#${t}`).join(' ');
    const text = tags ? `${d.text}\n\n${tags}` : d.text;
    const imageUrl = d.selectedImage !== 'none' ? imgUrl(d.selectedImage) : null;
    const articleUrl = buildArticleUrl();
    const result = await api(`${p}/publish`, 'POST', { text, options:{ imageUrl, articleUrl } });
    if (result.success) {
      // Map connector result (postUrl) to writeback shape (url) used by renderPublished
      state.writebacks[p] = { postId: result.postId, url: result.postUrl, publishedAt: result.publishedAt, text };
      render();
    }
  } catch(e) { alert(`Publish to ${PLATFORMS[p].displayName} failed: ${e.message}`); }
  finally { state.publishing[p] = false; }
}

function handleSaveAll() {
  if (window.self === window.top) return;
  const draftsWithImageUrl = {};
  Object.keys(PLATFORMS).forEach(p => {
    const d = state.drafts[p];
    draftsWithImageUrl[p] = { ...d, imageUrl: d.selectedImage !== 'none' ? imgUrl(d.selectedImage) : null };
  });
  window.parent.postMessage({ type:'metadata-update', info:{ socialMediaDraft:draftsWithImageUrl } }, state.neonAppUrl||'*');
}

// --- Metrics polling ---
function startMetricsPoll(p) {
  if (state.metricsIntervals[p]) return;
  const postId = state.writebacks[p]?.postId;
  if (!postId) return;
  const poll = async () => {
    if (document.hidden) return;
    try {
      const res = await api(`${p}/metrics/${encodeURIComponent(postId)}`);
      if (res.success && state.writebacks[p]) {
        state.writebacks[p].metrics = res.metrics;
        if (state.active === p) updateMetricCards(p, res.metrics);
      }
    } catch(_) {}
  };
  poll();
  state.metricsIntervals[p] = setInterval(poll, 30000);
}

document.addEventListener('visibilitychange', () => {
  if (!document.hidden) {
    Object.keys(PLATFORMS).forEach(p => { if (state.metricsIntervals[p] && state.writebacks[p]) startMetricsPoll(p); });
  }
});

// --- Helpers ---
function buildArticleUrl() {
  const ch = state.neonContext?.channel || {};
  const base = ch.frontofficeUrls?.[0] || ch.frontofficeUrl || '';
  const node = state.neonContext?.originalNode || {};
  const slug = node.slug || node.name || node.uuid || '';
  return base && slug ? `${base}/${slug}` : null;
}

// --- Init ---
async function init() {
  render();
  if (window.self !== window.top) {
    window.parent.postMessage({ type:'panel-ready', info:{ op:'getInfo' } }, '*');
  }
  await loadStatuses();
}
init();
</script>
</body>
</html>
