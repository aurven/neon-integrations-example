<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartOcto - Content Analytics</title>
    <!-- Panel Bootstrap (inline with dynamic resource loading to avoid path issues when embedded) -->
    <script>(function(w){'use strict';function e(){try{return w.self!==w.top}catch(e){return true}}const m=e(),p=m?'/neon/api/demo-integration':'';w.__PANEL_EMBED_PREFIX__=p;w.__PANEL_IS_EMBEDDED__=m;const l=document.createElement('link');l.rel='stylesheet';l.href=p+'/css/tailwind-panels.css';document.head.appendChild(l);const s=document.createElement('script');s.src=p+'/js/panel-api-helper.js';document.head.appendChild(s)})(window);</script>
    <script src="/js/chart.js"></script>
    <script src="/neon/api/demo-integration/js/chart.js"></script>
    <script src="/js/smartocto-data-generator.js"></script>
    <script src="/neon/api/demo-integration/js/smartocto-data-generator.js"></script>
    <script src="/js/smartocto-charts.js"></script>
    <script src="/neon/api/demo-integration/js/smartocto-charts.js"></script>
    <style>
        /* Modern font stack */
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        /* SmartOcto color variables */
        :root {
            --so-purple: #7C3AED;
            --so-teal: #14B8A6;
            --so-blue: #3B82F6;
            --so-green: #10B981;
            --so-orange: #F59E0B;
            --so-red: #EF4444;
            --so-text-primary: #1F2937;
            --so-text-secondary: #6B7280;
            --so-border: #E5E7EB;
            --so-background: #F9FAFB;
        }

        /* Chart containers */
        .chart-container {
            position: relative;
            width: 100%;
            height: 300px;
        }

        .chart-container-small {
            position: relative;
            width: 100%;
            height: 250px;
        }

        /* Live indicator pulse animation */
        @keyframes pulse-live {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .live-indicator {
            animation: pulse-live 2s ease-in-out infinite;
        }

        /* Score gauge styling */
        .score-gauge {
            background: linear-gradient(90deg, #EF4444 0%, #F59E0B 25%, #14B8A6 50%, #10B981 75%, #7C3AED 100%);
        }

        /* Recommendation card hover effect */
        .recommendation-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            transition: all 0.2s ease;
        }
    </style>
</head>

<body class="bg-gray-50">
    <div class="min-h-screen p-6">
        <div class="max-w-7xl mx-auto">
            <!-- Header with SmartOcto Logo -->
            <div class="bg-white rounded-lg shadow-sm p-4 mb-4 border border-gray-200">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <!-- SmartOcto Logo (Stylized) -->
                        <div class="w-12 h-12 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #7C3AED 0%, #14B8A6 100%);">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                            </svg>
                        </div>
                        <div>
                            <h1 class="text-lg font-semibold text-gray-900">SmartOcto Analytics</h1>
                            <div class="text-xs text-gray-500">
                                <span>Content Intelligence</span>
                                <span class="mx-1">›</span>
                                <span>Performance</span>
                                <span class="mx-1">›</span>
                                <div class="font-medium text-gray-700" id="breadcrumb-title">Article Insights</div>
                            </div>
                        </div>
                    </div>
                    <!-- Live indicator -->
                    <div class="px-3 py-1.5 bg-purple-50 text-purple-700 rounded-full text-xs font-semibold flex items-center space-x-1.5" id="live-badge" style="display: none;">
                        <span class="w-2 h-2 bg-purple-600 rounded-full live-indicator"></span>
                        <span>LIVE</span>
                    </div>
                </div>
                <div class="flex items-center space-x-2 mt-4">
                    <span class="text-xs text-gray-500">Time range</span>
                    <div class="px-3 py-1 bg-gray-100 rounded text-xs font-medium text-gray-700">
                        <span id="date-range">Last 24 hours</span>
                    </div>
                </div>
            </div>

            <!-- Core Metrics Grid (2 cols on mobile, 3 cols on tablet, 6 cols on desktop) -->
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-4">
                <!-- Attention Score Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border-2 border-purple-200">
                    <div class="mb-2">
                        <span class="text-xs font-semibold text-purple-600 uppercase block mb-1">⚡ Attention Score</span>
                        <span class="trend-indicator text-xs font-semibold" id="attention-trend"></span>
                    </div>
                    <div class="text-3xl font-bold text-purple-600" id="metric-attention">0</div>
                    <div class="mt-2 h-1.5 rounded-full score-gauge opacity-30"></div>
                </div>

                <!-- Page Views Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-semibold text-gray-500 uppercase block mb-1">👁️ Page Views</span>
                        <span class="trend-indicator text-xs font-semibold" id="views-trend"></span>
                    </div>
                    <div class="text-2xl font-semibold text-gray-900" id="metric-views">0</div>
                </div>

                <!-- Read Ratio Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-semibold text-gray-500 uppercase block mb-1">📖 Read Ratio</span>
                        <span class="trend-indicator text-xs font-semibold" id="readratio-trend"></span>
                    </div>
                    <div class="text-2xl font-semibold text-gray-900" id="metric-readratio">0%</div>
                </div>

                <!-- Avg Engagement Time Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-semibold text-gray-500 uppercase block mb-1">⏱️ Avg Time</span>
                        <span class="trend-indicator text-xs font-semibold" id="time-trend"></span>
                    </div>
                    <div class="text-2xl font-semibold text-gray-900" id="metric-time">0:00</div>
                </div>

                <!-- Recirculation Rate Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-semibold text-gray-500 uppercase block mb-1">🔄 Recirculation</span>
                        <span class="trend-indicator text-xs font-semibold" id="recirc-trend"></span>
                    </div>
                    <div class="text-2xl font-semibold text-gray-900" id="metric-recirc">0%</div>
                </div>

                <!-- Social Shares Card -->
                <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-200">
                    <div class="mb-2">
                        <span class="text-xs font-semibold text-gray-500 uppercase block mb-1">📤 Shares</span>
                        <span class="trend-indicator text-xs font-semibold" id="shares-trend"></span>
                    </div>
                    <div class="text-2xl font-semibold text-gray-900" id="metric-shares">0</div>
                </div>
            </div>

            <!-- Performance Lifecycle Chart -->
            <div class="bg-white rounded-lg shadow-sm p-6 mb-4 border border-gray-200">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-base font-semibold text-gray-900">📈 Performance Lifecycle</h3>
                    <div class="text-xs text-gray-500">Views over last 24 hours</div>
                </div>
                <div class="chart-container">
                    <canvas id="lifecycle-chart"></canvas>
                </div>
            </div>

            <!-- Two column layout for Traffic Sources and Read Depth -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
                <!-- Traffic Sources Chart -->
                <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
                    <h3 class="text-base font-semibold text-gray-900 mb-4">🌐 Traffic Sources</h3>
                    <div class="chart-container-small">
                        <canvas id="traffic-sources-chart"></canvas>
                    </div>
                </div>

                <!-- Read Depth Distribution -->
                <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
                    <h3 class="text-base font-semibold text-gray-900 mb-4">📊 Read Depth Distribution</h3>
                    <div class="chart-container-small">
                        <canvas id="read-depth-chart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Two column layout for Engagement Funnel and Device Performance -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
                <!-- Engagement Funnel -->
                <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
                    <h3 class="text-base font-semibold text-gray-900 mb-4">🎯 Engagement Funnel</h3>
                    <div class="chart-container-small">
                        <canvas id="engagement-funnel-chart"></canvas>
                    </div>
                    <div class="mt-4 grid grid-cols-2 gap-2 text-xs">
                        <div class="p-2 bg-purple-50 rounded">
                            <div class="text-gray-600">Reader Conversion</div>
                            <div class="text-lg font-semibold text-purple-700" id="funnel-reader-rate">0%</div>
                        </div>
                        <div class="p-2 bg-teal-50 rounded">
                            <div class="text-gray-600">Engagement Rate</div>
                            <div class="text-lg font-semibold text-teal-700" id="funnel-engaged-rate">0%</div>
                        </div>
                    </div>
                </div>

                <!-- Device Performance -->
                <div class="bg-white rounded-lg shadow-sm p-6 border border-gray-200">
                    <h3 class="text-base font-semibold text-gray-900 mb-4">📱 Device Performance</h3>
                    <div class="chart-container-small">
                        <canvas id="device-chart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Content Quality Metrics -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
                <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg shadow-sm p-5 border border-purple-200">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-sm font-semibold text-purple-800">Content Health Score</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="text-3xl font-bold text-purple-700" id="metric-health">0</div>
                    <div class="text-xs text-purple-700 mt-1" id="health-label">Excellent</div>
                </div>

                <div class="bg-gradient-to-br from-teal-50 to-teal-100 rounded-lg shadow-sm p-5 border border-teal-200">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-sm font-semibold text-teal-800">Completion Rate</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="text-3xl font-bold text-teal-700" id="metric-completion">0%</div>
                    <div class="text-xs text-teal-700 mt-1">readers finish article</div>
                </div>

                <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg shadow-sm p-5 border border-blue-200">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-sm font-semibold text-blue-800">Loyalty Index</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                    </div>
                    <div class="text-3xl font-bold text-blue-700" id="metric-loyalty">0%</div>
                    <div class="text-xs text-blue-700 mt-1">returning visitor engagement</div>
                </div>
            </div>

            <!-- AI Recommendations Panel -->
            <div class="bg-gradient-to-br from-purple-50 via-white to-teal-50 rounded-lg shadow-sm p-6 mb-4 border-2 border-purple-200">
                <div class="flex items-center space-x-2 mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                    <h3 class="text-base font-semibold text-gray-900">💡 SmartOcto AI Recommendations</h3>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="recommendations-container">
                    <!-- Recommendations will be inserted here -->
                </div>
            </div>

            <!-- Footer -->
            <div class="mt-6 text-center text-xs text-gray-500" hidden>
                <p>Demo data generated for illustration • Powered by SmartOcto Content Intelligence</p>
            </div>
        </div>
    </div>

    <script>
        // Get objectId from URL parameters
        const urlParams = new URLSearchParams(window.location.search);
        const objectId = urlParams.get('objectId') || 'demo-article-uuid-12345';

        // Generate SmartOcto metrics data
        const metricsData = SmartOctoDataGenerator.generateSmartOctoMetrics(objectId);

        // Update breadcrumb
        //document.getElementById('breadcrumb-title').textContent = objectId.substring(0, 16) + '...';
        document.getElementById('breadcrumb-title').textContent = objectId;

        // Show live badge if data is live
        if (metricsData.isLive) {
            document.getElementById('live-badge').style.display = 'flex';
        }

        // Update core metrics
        document.getElementById('metric-attention').textContent = metricsData.attentionScore;
        document.getElementById('metric-views').textContent = metricsData.pageViews.toLocaleString();
        document.getElementById('metric-readratio').textContent = metricsData.readRatio.toFixed(1) + '%';
        document.getElementById('metric-time').textContent = metricsData.avgEngagementTimeFormatted;
        document.getElementById('metric-recirc').textContent = metricsData.recirculationRate.toFixed(1) + '%';
        document.getElementById('metric-shares').textContent = metricsData.socialShares.toLocaleString();

        // Update quality metrics
        document.getElementById('metric-health').textContent = metricsData.contentHealthScore;
        document.getElementById('metric-completion').textContent = metricsData.completionRate.toFixed(1) + '%';
        document.getElementById('metric-loyalty').textContent = metricsData.loyaltyIndex.toFixed(1) + '%';

        // Update health label based on score
        const healthScore = metricsData.contentHealthScore;
        const healthLabelEl = document.getElementById('health-label');
        if (healthScore >= 90) {
            healthLabelEl.textContent = 'Exceptional';
        } else if (healthScore >= 80) {
            healthLabelEl.textContent = 'Excellent';
        } else if (healthScore >= 70) {
            healthLabelEl.textContent = 'Good';
        } else if (healthScore >= 60) {
            healthLabelEl.textContent = 'Fair';
        } else {
            healthLabelEl.textContent = 'Needs Improvement';
        }

        // Update funnel conversion rates
        document.getElementById('funnel-reader-rate').textContent = metricsData.engagementFunnel.visitorToReader.toFixed(1) + '%';
        document.getElementById('funnel-engaged-rate').textContent = metricsData.engagementFunnel.readerToEngaged.toFixed(1) + '%';

        // Update trends
        function updateTrend(elementId, trend, inverse = false) {
            const indicator = SmartOctoDataGenerator.getTrendIndicator(trend, inverse);
            const element = document.getElementById(elementId);
            element.textContent = indicator.icon + ' ' + indicator.value;
            element.className = 'text-xs font-semibold ' + indicator.color;
        }

        updateTrend('attention-trend', metricsData.trends.attentionScore);
        updateTrend('views-trend', metricsData.trends.pageViews);
        updateTrend('readratio-trend', metricsData.trends.readRatio);
        updateTrend('time-trend', metricsData.trends.avgEngagementTime);
        updateTrend('recirc-trend', metricsData.trends.recirculationRate);
        updateTrend('shares-trend', metricsData.trends.socialShares);

        // Render AI recommendations
        const recommendationsContainer = document.getElementById('recommendations-container');
        metricsData.recommendations.forEach(rec => {
            const priorityColor = SmartOctoDataGenerator.getPriorityColor(rec.priority);
            const recCard = document.createElement('div');
            recCard.className = 'recommendation-card bg-white rounded-lg p-4 border border-gray-200';
            recCard.innerHTML = `
                <div class="flex items-start space-x-2">
                    <div class="flex-shrink-0">
                        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold ${priorityColor}">${rec.priority.toUpperCase()}</span>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-gray-700">${rec.text}</p>
                    </div>
                </div>
            `;
            recommendationsContainer.appendChild(recCard);
        });

        // Initialize charts when Chart.js is loaded
        window.addEventListener('load', function() {
            // Performance lifecycle chart
            SmartOctoCharts.initLifecycleChart(
                'lifecycle-chart',
                metricsData.lifecycleLabels,
                metricsData.lifecycleData
            );

            // Traffic sources chart
            SmartOctoCharts.initTrafficSourcesChart(
                'traffic-sources-chart',
                metricsData.trafficSources
            );

            // Read depth distribution chart
            SmartOctoCharts.initReadDepthChart(
                'read-depth-chart',
                metricsData.scrollDepth
            );

            // Engagement funnel chart
            SmartOctoCharts.initEngagementFunnelChart(
                'engagement-funnel-chart',
                metricsData.engagementFunnel
            );

            // Device performance chart
            SmartOctoCharts.initDeviceChart(
                'device-chart',
                metricsData.devices
            );

            console.log('SmartOcto Analytics Panel loaded with data:', metricsData);
        });
    </script>
</body>

</html>
