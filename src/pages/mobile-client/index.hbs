<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{seo.title}}</title>
    <link rel="stylesheet" href="/mobile-client.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="mobile-container">
        <!-- Header -->
        <header class="header">
            <h1><i class="fas fa-newspaper"></i> Article Manager</h1>
            <button class="btn btn-primary create-btn" onclick="createNewArticle()">
                <i class="fas fa-plus"></i> Create Article
            </button>
        </header>

        <!-- Article List -->
        <main class="main-content">
            {{#if articles.length}}
            <div class="articles-container" id="articlesContainer">
                {{#each articles}}
                <div class="article-card" data-uuid="{{familyRef}}">
                    <div class="article-header">
                        <h3 class="article-title">{{title}}</h3>
                        {{#if workflowInfo}}
                        <span class="article-status-chip">
                            <span class="status-dot" style="background-color: {{workflowInfo.color}};"></span>
                            {{workflowInfo.workflow}}
                        </span>
                        {{else}}
                        <span class="article-status-chip">
                            <span class="status-dot" style="background-color: rgb(150, 150, 150);"></span>
                            Unknown
                        </span>
                        {{/if}}
                    </div>

                    <p class="article-summary">{{#if nodeMeta.teaser.title}}{{nodeMeta.teaser.title}}{{else}}{{title}}{{/if}}</p>

                    <div class="article-meta">
                        <span class="article-date">
                            <i class="fas fa-clock"></i>
                            {{formatDate updateTs}}
                        </span>
                        <span class="article-uuid">
                            <i class="fas fa-fingerprint"></i>
                            {{familyRef}}
                        </span>
                    </div>

                    <div class="article-actions">
                        <button class="btn btn-secondary" onclick="editArticle('{{familyRef}}')">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <button class="btn btn-info" onclick="viewArticle('{{familyRef}}')">
                            <i class="fas fa-eye"></i> View
                        </button>
                        <button class="btn btn-danger" onclick="deleteArticle('{{familyRef}}')">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            <!-- Empty state -->
            <div class="empty-state" id="emptyState">
                <i class="fas fa-file-alt"></i>
                <h3>No Articles Found</h3>
                <p>Create your first article to get started.</p>
                <button class="btn btn-primary" onclick="createNewArticle()">
                    <i class="fas fa-plus"></i> Create First Article
                </button>
            </div>
            {{/if}}

            <!-- Loading state -->
            <div class="loading-state" id="loadingState" style="display: none;">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Loading articles...</p>
            </div>
        </main>

        <!-- Footer -->
        <footer class="footer">
            <p>&copy; 2025 Neon Mobile Client POC</p>
        </footer>
    </div>

    <!-- Modal for confirmations -->
    <div class="modal" id="confirmModal" style="display: none;">
        <div class="modal-content">
            <h3>Confirm Action</h3>
            <p id="confirmMessage"></p>
            <div class="modal-actions">
                <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
                <button class="btn btn-danger" id="confirmButton" onclick="confirmAction()">Confirm</button>
            </div>
        </div>
    </div>

    <script src="/mobile-client.js"></script>
</body>
</html>