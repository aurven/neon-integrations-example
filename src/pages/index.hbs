<!DOCTYPE html>
<html lang="en">
  <head>
    
    <meta charset="utf-8" />
    <link rel="icon" href="/assets/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{{seo.title}}</title>
    
    <!-- Meta tags for SEO and social sharing -->
    <link rel="canonical" href="{{seo.url}}">
    <meta name="description" content="{{seo.description}}">
    <meta property="og:title" content="{{seo.title}}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="{{seo.url}}">
    <meta property="og:description" content="{{seo.description}}">
    <meta property="og:image" content="{{seo.image}}">
    <meta name="twitter:card" content="summary">

    <!-- Import the webpage's stylesheet -->
    <link rel="stylesheet" href="/style.css" />   
  </head>
  <body>
    <div class="wrapper">
      <div class="content" role="main">
        <h1 class="title">Hello Neon!</h1>
        <div class="instructions">
          <h2>
            Using this integration example with Node.js and Fastify
          </h2>
          <p>
            This is the Node <strong>neon-integrations-example</strong> project.<br>
            From here you can create a new application to create simple Node.js
            integrations between Neon and the rest of the world.
          </p>
        </div>
        
        <!-- Navigation to Services Dashboard -->
        <div class="services-nav">
          <a href="/services" class="services-link">
            <div class="services-box">
              <h3>Services Dashboard</h3>
              <p>View all available integrations and services</p>
              <span class="arrow">→</span>
            </div>
          </a>
        </div>
        
      </div>
    </div>
    
    <footer class="footer" hidden>
      <div class="links">Eidosmedia S.p.a. - 2025</div>
    </footer>
    <script></script> 
  </body>
</html>
