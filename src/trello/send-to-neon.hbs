<html>
  <head>
    <link rel="stylesheet" href="https://p.trellocdn.com/power-up.min.css" />
    <style>
      select {
        height: 30px;
      }
      .loading {
        opacity: 0.6;
        pointer-events: none;
      }
      .spinner {
        display: inline-block;
        width: 12px;
        height: 12px;
        border: 2px solid #f3f3f3;
        border-top: 2px solid #026aa7;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-right: 5px;
      }
      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
      .hidden {
        display: none;
      }
    </style>
    <script src="https://p.trellocdn.com/power-up.min.js"></script>
  </head>
  <body>
    <form id="neon">
      <label for="prioritySize">Priority:</label>
      <select name="prioritySize" id="prioritySize">
        <option value="9">🟥 Critical!</option>
        <option value="8">🟧 High</option>
        <option value="5">🟨 Medium</option>
        <option value="0">🟩 Low</option>
      </select>
      <label for="neonId">Neon Id:</label>
      <input type="text" name="neonId" id="neonId" placeholder="None" disabled/>
      <button type="submit" class="mod-primary" id="submitBtn">Create in Neon</button>
      <button id="openInNeon" type="button" class="mod-primary hidden">Open in Neon</button>
      <button id="cleanCard" type="button" class="hidden" title="Clean this topic">🧹</button>
    </form>
    <script>
      var t = TrelloPowerUp.iframe();
      
      window.openInNeon.addEventListener("click", function(event) {
        event.preventDefault();
        const familyRef = window.neonId.value;
        familyRef && window.open(`{{neonAppUrl}}/neon/app/neon.html#open/${familyRef}`);
      });
      
      window.cleanCard.addEventListener("click", function(event) {
        event.preventDefault();
        t.set("card", "shared", "neonId", null)
          .then(function() {
            return t.set("card", "shared", "priority", null);
          })
          .then(function() {
            window.neonId.value = '';
            window.prioritySize.value = '0';
            updateButtonVisibility(false);
            t.sizeTo("#neon").done();
          })
          .catch(function(error) {
            console.error('Error cleaning card:', error);
          });
      });
      
      function updateButtonVisibility(hasNeonId) {
        if (hasNeonId) {
          window.submitBtn.classList.add('hidden');
          window.openInNeon.classList.remove('hidden');
          window.cleanCard.classList.remove('hidden');
        } else {
          window.submitBtn.classList.remove('hidden');
          window.openInNeon.classList.add('hidden');
          window.cleanCard.classList.add('hidden');
        }
      }
      
      window.neon.addEventListener("submit", function (event) {
        // Stop the browser trying to submit the form itself.
        event.preventDefault();
        
        // Show loading state
        const submitBtn = window.submitBtn;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="spinner"></span>Creating...';
        submitBtn.classList.add('loading');
        return t
          .set("card", "shared", "priority", window.prioritySize.value)
          .then(function () {
            t.card('all')
              .then(function (data) {
                console.log(JSON.stringify(data, null, 2));
                return data
              })
              .then(function (data) {
                t.get('member', 'private')
                  .then(memberInfo => {
                  
                  console.log(memberInfo);
                  
                  const token = memberInfo.authToken;
                  const neonUsername = memberInfo.neonUsername;
                  
                  data.neonUsername = neonUsername;

                  const requestHeaders = new Headers();
                  requestHeaders.append("ApiKey", token);

                  const requestOptions = {
                    method: "POST",
                    headers: requestHeaders,
                    redirect: "follow",
                    body: JSON.stringify(data)
                  };
                  
                  console.log(requestOptions);

                  fetch("/in/trello/neon", requestOptions)
                    .then((response) => response.json())
                    .then((result) => {
                      console.log("result");
                      console.log(result);
                      t.set("card", "shared", "neonId", result.data?.neon?.familyRef)
                        .then((result) => {
                          console.log("result after set");
                          console.log(result);
                          // Reset button state
                          submitBtn.innerHTML = originalText;
                          submitBtn.classList.remove('loading');
                          t.closePopup();
                        });
                    })
                    .catch((error) => {
                      console.error(error);
                      // Reset button state on error
                      submitBtn.innerHTML = originalText;
                      submitBtn.classList.remove('loading');
                    })
                });
              });
          });
      });
      
      t.render(function () {
          return t
            .get("card", "shared")
            .then(function (cardInfo) {
              const {priority, neonId} = cardInfo;
              window.prioritySize.value = priority || '0';
              window.neonId.value = neonId || '';
              if (!neonId) {
                window.neonId.style.display = 'none';
              }
              updateButtonVisibility(!!neonId);
            })
            .then(function () {
              t.sizeTo("#neon").done();
            });
      });
    </script>
  </body>
</html>
